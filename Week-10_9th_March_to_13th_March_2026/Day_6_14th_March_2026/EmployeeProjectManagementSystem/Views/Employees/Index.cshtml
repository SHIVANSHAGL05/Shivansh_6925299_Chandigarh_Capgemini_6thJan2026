@model IEnumerable<EmployeeProjectManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<h2>Employees</h2>
<a asp-action="Create">Create New</a>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Projects</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Name</td>
                <td>@employee.Email</td>
                <td>@employee.Department?.Name</td>
                <td>@employee.EmployeeProjects.Count</td>
                <td>
                    <a asp-action="Details" asp-route-id="@employee.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@employee.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@employee.Id">Delete</a> |
                    <a asp-action="EmployeeProjects" asp-route-id="@employee.Id">Projects</a>
                </td>
            </tr>
        }
    </tbody>
</table>
