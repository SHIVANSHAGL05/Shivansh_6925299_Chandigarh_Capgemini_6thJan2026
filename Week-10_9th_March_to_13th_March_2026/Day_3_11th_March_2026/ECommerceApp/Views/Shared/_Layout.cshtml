<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Commerce App</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/Products/Index">🛒 E-Commerce</a>
            <div class="ms-auto d-flex gap-2">
                <a href="/Products/Index" class="btn btn-outline-light btn-sm">Products</a>
                <a href="/Customers/Index" class="btn btn-outline-light btn-sm">Customers</a>
                <a href="/Orders/Index" class="btn btn-outline-warning btn-sm">Orders</a>
            </div>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
</body>
</html>