@model ECommerceOMS.ViewModels.CustomerHistoryViewModel
@{
    ViewData["Title"] = Model.Customer.FullName + " – History";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Customers</a></li>
        <li class="breadcrumb-item active">@Model.Customer.FullName</li>
    </ol>
</nav>

<div class="row g-4">
    <!-- Profile Card -->
    <div class="col-md-4">
        <div class="card p-4 text-center mb-3">
            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3"
                 style="width:80px;height:80px;font-size:2rem;">
                @Model.Customer.FirstName[0]@Model.Customer.LastName[0]
            </div>
            <h5 class="fw-bold">@Model.Customer.FullName</h5>
            <p class="text-muted small mb-0">@Model.Customer.Email</p>
            <p class="text-muted small">@Model.Customer.Phone</p>
            <hr>
            <div class="text-start small">
                <p class="mb-1"><i class="bi bi-geo-alt me-2 text-primary"></i>@Model.Customer.Address</p>
                <p class="mb-1"><i class="bi bi-building me-2 text-primary"></i>@Model.Customer.City – @Model.Customer.PostalCode</p>
                <p class="mb-0"><i class="bi bi-calendar me-2 text-primary"></i>Since @Model.Customer.RegisteredOn.ToString("MMM yyyy")</p>
            </div>
            <div class="mt-3 d-flex gap-2 justify-content-center">
                <a asp-action="Edit" asp-route-id="@Model.Customer.Id" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
            </div>
        </div>

        <!-- Summary Stats -->
        <div class="card p-3">
            <h6 class="fw-bold mb-3">Summary</h6>
            <div class="row g-2 text-center">
                <div class="col-6">
                    <div class="bg-soft-primary rounded p-2">
                        <div class="fw-bold text-primary fs-4">@Model.TotalOrders</div>
                        <div class="text-muted small">Orders</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="bg-soft-primary rounded p-2">
                        <div class="fw-bold text-success fs-5">₹@Model.TotalSpent.ToString("N0")</div>
                        <div class="text-muted small">Spent</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Order History -->
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Order History</h5>
            <a asp-controller="Order" asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-cart-plus me-1"></i>New Order
            </a>
        </div>

        @if (!Model.Orders.Any())
        {
            <div class="card text-center py-5">
                <i class="bi bi-cart-x display-3 text-muted opacity-25"></i>
                <p class="mt-2 text-muted">No orders placed yet.</p>
            </div>
        }
        else
        {
            @foreach (var od in Model.Orders)
            {
                var statusClass = od.Order.Status.ToString().ToLower();
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                        <div>
                            <span class="fw-bold">#@od.Order.OrderNumber</span>
                            <span class="text-muted small ms-2">@od.Order.OrderDate.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge badge-@statusClass">@od.Order.Status</span>
                            <a asp-controller="Order" asp-action="Details" asp-route-id="@od.Order.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in od.OrderItems)
                                {
                                    <tr>
                                        <td class="small">@item.Product?.Name</td>
                                        <td class="text-center small">@item.Quantity</td>
                                        <td class="text-end small">₹@item.UnitPrice.ToString("N2")</td>
                                        <td class="text-end small fw-semibold">₹@(item.Quantity * item.UnitPrice)</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-light">
                                    <td colspan="3" class="text-end fw-bold">Total</td>
                                    <td class="text-end fw-bold text-primary">₹@od.TotalAmount.ToString("N2")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    @if (od.ShippingDetail != null)
                    {
                        <div class="card-footer small text-muted py-2">
                            <i class="bi bi-truck me-1"></i>
                            Shipping: <strong>@od.ShippingDetail.Status</strong>
                            @if (od.ShippingDetail.TrackingNumber != null)
                            {
                                <span class="ms-2">· Tracking: @od.ShippingDetail.TrackingNumber</span>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
