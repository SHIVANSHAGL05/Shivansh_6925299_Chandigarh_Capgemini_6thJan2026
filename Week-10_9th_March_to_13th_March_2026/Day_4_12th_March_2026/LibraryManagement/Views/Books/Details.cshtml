@model LibraryManagement.Models.Book
@{ ViewData["Title"] = "Book Details"; }

<div class="mb-4">
    <h4 class="fw-bold mb-0">Book Details</h4>
    <!-- Shows the route: /Books/Details/@Model.BookId -->
    <small class="text-muted">
        Route: <code>/Books/Details/@Model.BookId</code> →
        <code>BooksController.Details(@Model.BookId)</code> →
        <code>_bookRepository.GetByIdAsync(@Model.BookId)</code>
    </small>
</div>

<div class="row g-4">
    <!-- Book Info Card -->
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-book me-2"></i>Book Information
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">#@Model.BookId</dd>

                    <dt class="col-sm-4">Title</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Title</dd>

                    <dt class="col-sm-4">Author</dt>
                    <dd class="col-sm-8">@Model.Author</dd>

                    <dt class="col-sm-4">ISBN</dt>
                    <dd class="col-sm-8"><code>@Model.ISBN</code></dd>

                    <dt class="col-sm-4">Genre</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-light text-dark border">@Model.Genre</span>
                    </dd>

                    <dt class="col-sm-4">Published</dt>
                    <dd class="col-sm-8">@Model.PublishedDate.ToShortDateString()</dd>

                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8 text-success fw-bold">@Model.Price.ToString("C")</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsAvailable)
                        {
                            <span class="badge-available">
                                <i class="bi bi-check-circle me-1"></i>Available
                            </span>
                        }
                        else
                        {
                            <span class="badge-unavailable">
                                <i class="bi bi-x-circle me-1"></i>Checked Out
                            </span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer bg-white border-top-0 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.BookId"
                   class="btn btn-sm btn-warning text-white">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Back
                </a>
            </div>
        </div>
    </div>

    <!-- Description + DI Flow Card -->
    <div class="col-md-7">
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-card-text me-2"></i>Description
            </div>
            <div class="card-body">
                <p class="mb-0">@(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)</p>
            </div>
        </div>

        <!-- DI Flow explanation box -->
        <div class="card border-0" style="background:#eaf1fb">
            <div class="card-body">
                <h6 class="fw-bold text-primary mb-3">
                    <i class="bi bi-diagram-2 me-2"></i>How DI + Repository fetched this book
                </h6>
                <ol class="mb-0" style="font-size:.85rem; color:#2d2d2d">
                    <li class="mb-1">
                        Browser requested <code>/Books/Details/@Model.BookId</code>
                    </li>
                    <li class="mb-1">
                        Conventional route matched:
                        <code>controller=Books, action=Details, id=@Model.BookId</code>
                    </li>
                    <li class="mb-1">
                        DI container created <code>BooksController</code> and
                        injected <code>IBookRepository</code> (resolved as <code>BookRepository</code>)
                    </li>
                    <li class="mb-1">
                        <code>Details(@Model.BookId)</code> called
                        <code>_bookRepository.GetByIdAsync(@Model.BookId)</code>
                    </li>
                    <li class="mb-0">
                        EF Core ran <code>SELECT * FROM Books WHERE BookId = @Model.BookId</code>
                        and returned this book
                    </li>
                </ol>
            </div>
        </div>
    </div>
</div>
