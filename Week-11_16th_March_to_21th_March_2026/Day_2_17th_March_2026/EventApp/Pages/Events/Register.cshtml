@page
@model EventApp.Pages.Events.RegisterModel
@{
    ViewData["Title"] = "Register for Event";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-7">

        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0">🗓️ Event Registration</h4>
                <small class="opacity-75">Fill in your details to secure your spot</small>
            </div>

            <div class="card-body p-4">

                @* Task 3: Form posting to OnPost() handler *@
                <form method="post">
                    @* Anti-forgery token is automatically injected by Razor Pages *@
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                    @* Participant Name *@
                    <div class="mb-3">
                        <label asp-for="Registration.ParticipantName" class="form-label fw-semibold"></label>
                        <input asp-for="Registration.ParticipantName" class="form-control"
                               placeholder="e.g. John Smith" />
                        @* Task 3: Validation message from data annotations *@
                        <span asp-validation-for="Registration.ParticipantName" class="text-danger small"></span>
                    </div>

                    @* Email *@
                    <div class="mb-3">
                        <label asp-for="Registration.Email" class="form-label fw-semibold"></label>
                        <input asp-for="Registration.Email" class="form-control"
                               type="email" placeholder="e.g. john@example.com" />
                        <span asp-validation-for="Registration.Email" class="text-danger small"></span>
                    </div>

                    @* Event Name dropdown *@
                    <div class="mb-4">
                        <label asp-for="Registration.EventName" class="form-label fw-semibold"></label>
                        <select asp-for="Registration.EventName"
                                asp-items="Model.AvailableEvents"
                                class="form-select">
                            <option value="">-- Choose an Event --</option>
                        </select>
                        <span asp-validation-for="Registration.EventName" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Register Now</button>
                        <a asp-page="Index" class="btn btn-outline-secondary">View Participants</a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
