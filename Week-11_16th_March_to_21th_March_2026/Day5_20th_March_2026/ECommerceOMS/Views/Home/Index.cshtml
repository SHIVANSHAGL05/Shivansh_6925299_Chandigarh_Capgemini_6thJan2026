@{
    ViewData["Title"] = "Home";
}

<div class="hero-section mb-5">
    <div class="row align-items-center">
        <div class="col-md-7">
            <h1 class="display-5 fw-bold mb-3">Welcome to <span class="text-warning">E-CommerceOMS</span></h1>
            <p class="lead mb-4 opacity-75">Manage your e-commerce operations — products, orders, customers, and shipments — all in one place.</p>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Product" asp-action="Index" class="btn btn-warning btn-lg fw-semibold">
                    <i class="bi bi-grid me-2"></i>Browse Products
                </a>
                <a asp-controller="Order" asp-action="Create" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-cart-plus me-2"></i>New Order
                </a>
            </div>
        </div>
        <div class="col-md-5 text-center d-none d-md-block">
            <i class="bi bi-bag-heart-fill" style="font-size:9rem;opacity:.25;"></i>
        </div>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-5">
    <div class="col-6 col-md-4">
        <div class="card stat-card bg-primary text-white position-relative overflow-hidden p-3">
            <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
            <div class="text-white-50 small fw-semibold text-uppercase">Products</div>
            <div class="fs-2 fw-bold">@ViewBag.TotalProducts</div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card stat-card bg-success text-white position-relative overflow-hidden p-3">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="text-white-50 small fw-semibold text-uppercase">Customers</div>
            <div class="fs-2 fw-bold">@ViewBag.TotalCustomers</div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card stat-card bg-warning text-dark position-relative overflow-hidden p-3">
            <div class="stat-icon"><i class="bi bi-cart-check"></i></div>
            <div class="small fw-semibold text-uppercase opacity-75">Orders</div>
            <div class="fs-2 fw-bold">@ViewBag.TotalOrders</div>
        </div>
    </div>
</div>

<!-- Categories -->
@if (ViewBag.Categories != null)
{
    <h4 class="fw-bold mb-3"><i class="bi bi-tags me-2 text-primary"></i>Shop by Category</h4>
    <div class="row g-2 mb-5">
        @foreach (var cat in ViewBag.Categories)
        {
            <div class="col-6 col-sm-4 col-md-2">
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.Id"
                   class="card text-center p-3 text-decoration-none text-dark h-100">
                    <div class="fs-2 mb-1">
                        @{
                            var icon = cat.Name switch {
                                "Electronics" => "bi-cpu",
                                "Clothing" => "bi-bag",
                                "Books" => "bi-book",
                                "Home & Kitchen" => "bi-house",
                                "Sports" => "bi-trophy",
                                _ => "bi-grid"
                            };
                        }
                        <i class="bi @icon text-primary"></i>
                    </div>
                    <div class="small fw-semibold">@cat.Name</div>
                </a>
            </div>
        }
    </div>
}

<!-- Featured Products -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-star me-2 text-warning"></i>Featured Products</h4>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-sm">View All</a>
</div>
<div class="row g-3">
    @if (ViewBag.FeaturedProducts != null)
    {
        @foreach (var p in ViewBag.FeaturedProducts)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card product-card h-100">
                    <div class="product-img-placeholder">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-primary-subtle text-primary mb-1 small">@p.Category?.Name</span>
                        <h6 class="card-title fw-semibold mb-1">@p.Name</h6>
                        <p class="text-muted small flex-grow-1">@(p.Description?.Length > 60 ? p.Description.Substring(0, 60) + "…" : p.Description)</p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fs-5 fw-bold text-primary">₹@p.Price.ToString("N2")</span>
                            <span class="badge @(p.StockQuantity > 10 ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning") small">
                                @(p.StockQuantity > 0 ? "In Stock" : "Out of Stock")
                            </span>
                        </div>
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id"
                           class="btn btn-primary btn-sm mt-3">View Details</a>
                    </div>
                </div>
            </div>
        }
    }
</div>
