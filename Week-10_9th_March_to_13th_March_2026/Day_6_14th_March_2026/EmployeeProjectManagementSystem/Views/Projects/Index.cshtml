@model IEnumerable<EmployeeProjectManagementSystem.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<h2>Projects</h2>
<a asp-action="Create">Create New</a>

<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Employees</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.Title</td>
                <td>@project.Description</td>
                <td>@project.EmployeeProjects.Count</td>
                <td>
                    <a asp-action="Details" asp-route-id="@project.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@project.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@project.Id">Delete</a> |
                    <a asp-action="ProjectEmployees" asp-route-id="@project.Id">Employees</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<br />
<a asp-action="Dashboard">Project Dashboard</a>
