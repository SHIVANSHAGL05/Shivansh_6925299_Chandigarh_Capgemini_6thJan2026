@page
@model LearningPlatform.Web.Pages.Student.MyEnrollmentsModel
@{
    ViewData["Title"] = "My Learning";
}

<div class="page-header">
    <h1>📚 My Learning</h1>
    <a href="/Courses/Index" class="btn-primary">Browse More Courses</a>
</div>

@if (Model.Enrollments == null || !Model.Enrollments.Any())
{
    <div class="empty-state">
        <span class="empty-icon">🎓</span>
        <h3>No enrollments yet</h3>
        <p>Start learning by browsing our courses.</p>
        <a href="/Courses/Index" class="btn-primary">Browse Courses</a>
    </div>
}
else
{
    <div class="enrollment-grid">
        @foreach (var e in Model.Enrollments)
        {
            <div class="enrollment-card">
                <h3><a href="/Courses/Detail?id=@e.CourseId">@e.CourseTitle</a></h3>
                <div class="enrollment-meta">
                    <span>📅 Enrolled: @e.EnrolledAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                    <span class="status-badge status-@e.Status.ToLower()">@e.Status</span>
                </div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar" style="width:@e.ProgressPercent%"></div>
                </div>
                <small class="progress-label">@e.ProgressPercent% complete</small>
            </div>
        }
    </div>
}
