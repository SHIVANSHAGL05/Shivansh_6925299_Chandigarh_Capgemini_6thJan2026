@model HotelSimple.Models.Booking?
@{
    ViewData["Title"] = "My Booking";
}

<h2 class="mb-4"><i class="bi bi-search me-2"></i>Find My Booking</h2>

<!-- Alerts -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search form -->
<div class="card p-4 mb-4">
    <form method="get" action="/Booking/Lookup" class="row g-3 align-items-end">
        <div class="col-md-8">
            <label class="form-label fw-semibold">Enter Booking Reference</label>
            <input type="text" name="bookingRef" class="form-control form-control-lg"
                   placeholder="e.g. HB-001"
                   value="@Context.Request.Query["bookingRef"].ToString()"
                   required />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-search me-2"></i>Find Booking
            </button>
        </div>
    </form>
</div>

<!-- Booking result -->
@if (Model != null)
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Booking — @Model.BookingRef</h5>
            @{
                var badgeColour = Model.Status switch
                {
                    "Confirmed"  => "success",
                    "Cancelled"  => "danger",
                    _            => "secondary"
                };
            }
            <span class="badge bg-@badgeColour fs-6">@Model.Status</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-sm-6">
                    <p class="mb-1 text-muted small">Guest Name</p>
                    <p class="fw-semibold">@Model.Customer.FullName</p>
                </div>
                <div class="col-sm-6">
                    <p class="mb-1 text-muted small">Contact</p>
                    <p class="fw-semibold">@Model.Customer.Phone</p>
                </div>
                <div class="col-sm-6">
                    <p class="mb-1 text-muted small">Room</p>
                    <p class="fw-semibold">
                        @Model.Room.RoomNumber
                        <span class="badge bg-primary">@Model.Room.RoomType</span>
                    </p>
                </div>
                <div class="col-sm-6">
                    <p class="mb-1 text-muted small">Guests</p>
                    <p class="fw-semibold">@Model.Guests</p>
                </div>
                <div class="col-sm-6">
                    <p class="mb-1 text-muted small">Check-In</p>
                    <p class="fw-semibold">@Model.CheckIn.ToString("dd MMM yyyy")</p>
                </div>
                <div class="col-sm-6">
                    <p class="mb-1 text-muted small">Check-Out</p>
                    <p class="fw-semibold">@Model.CheckOut.ToString("dd MMM yyyy")</p>
                </div>
                <div class="col-sm-6">
                    <p class="mb-1 text-muted small">Nights</p>
                    <p class="fw-semibold">@Model.Nights</p>
                </div>
                <div class="col-sm-6">
                    <p class="mb-1 text-muted small">Total Amount</p>
                    <p class="fw-bold text-success fs-5">₹@Model.TotalAmount.ToString("N0")</p>
                </div>
            </div>
        </div>

        @if (Model.Status == "Confirmed")
        {
            <div class="card-footer">
                <div class="alert alert-warning small mb-2">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Cancellation cannot be undone.
                </div>
                <form method="post" action="/Booking/Cancel"
                      onsubmit="return confirm('Are you sure you want to cancel this booking?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-x-circle me-2"></i>Cancel Booking
                    </button>
                </form>
            </div>
        }
    </div>
}
