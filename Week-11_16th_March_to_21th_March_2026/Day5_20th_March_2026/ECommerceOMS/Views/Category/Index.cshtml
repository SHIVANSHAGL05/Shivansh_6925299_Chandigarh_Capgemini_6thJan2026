@model IEnumerable<ECommerceOMS.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-tags me-2"></i>Categories</h1>
            <p class="mb-0 opacity-75">Manage product categories</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-warning fw-semibold">
                <i class="bi bi-folder-plus me-1"></i>Add Category
            </a>
        }
    </div>
</div>

<div class="row g-3">
    @foreach (var cat in Model)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="fw-bold mb-0">@cat.Name</h5>
                        @if (cat.IsActive)
                        {
                            <span class="badge bg-success-subtle text-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                        }
                    </div>
                    <p class="text-muted small">@cat.Description</p>
                    <div class="d-flex align-items-center gap-2 mt-2">
                        <span class="badge bg-primary-subtle text-primary">@cat.Products.Count products</span>
                        <span class="text-muted small">Order: @cat.DisplayOrder</span>
                    </div>
                </div>
                <div class="card-footer bg-transparent d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-eye me-1"></i>View
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash me-1"></i>Delete
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>
