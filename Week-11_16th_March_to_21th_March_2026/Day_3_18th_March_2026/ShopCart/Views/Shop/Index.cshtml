@model List<ShopCart.Models.Product>
@{
    ViewData["Title"] = "Products";
    var categories    = ViewBag.Categories as List<string>;
    string selected   = ViewBag.SelectedCategory;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-grid me-2"></i>Our Products</h2>
    <span class="text-muted">@Model.Count item(s)</span>
</div>

<!-- Success alert -->
@if (TempData["Added"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Added"]
        <a href="/Cart" class="alert-link ms-2">View Cart →</a>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Category filter tabs -->
<ul class="nav nav-pills mb-4 flex-wrap">
    <li class="nav-item">
        <a class="nav-link @(selected=="All"?"active":"")" href="/Shop">All</a>
    </li>
    @if (categories != null)
    {
        @foreach (var cat in categories)
        {
            <li class="nav-item">
                <a class="nav-link @(selected==cat?"active":"")" href="/Shop?category=@cat">@cat</a>
            </li>
        }
    }
</ul>

<!-- Product Cards (Bootstrap card grid) -->
<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100 shadow-sm product-card">
                <img src="@product.ImageUrl" class="card-img-top product-img" alt="@product.Name" />
                <div class="card-body d-flex flex-column">
                    <span class="badge bg-secondary mb-2 align-self-start">@product.Category</span>
                    <h6 class="card-title fw-bold">@product.Name</h6>
                    <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="fs-5 fw-bold text-success">₹@product.Price.ToString("N0")</span>
                        <form method="post" action="/Shop/AddToCart">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId"  value="@product.Id" />
                            <input type="hidden" name="returnUrl"  value="/Shop?category=@selected" />
                            <button type="submit" class="btn btn-dark btn-sm">
                                <i class="bi bi-cart-plus me-1"></i>Add
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
