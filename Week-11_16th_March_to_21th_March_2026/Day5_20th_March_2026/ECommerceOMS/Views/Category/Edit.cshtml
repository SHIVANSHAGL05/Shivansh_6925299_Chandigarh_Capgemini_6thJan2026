@model ECommerceOMS.Models.Category
@{
    ViewData["Title"] = "Edit Category";
}
<div class="page-header"><h1><i class="bi bi-pencil me-2"></i>Edit Category</h1><p class="mb-0 opacity-75">@Model.Name</p></div>
<div class="row justify-content-center"><div class="col-md-6">
    <div class="card p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedOn" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="form-label fw-semibold"></label>
                <input asp-for="DisplayOrder" class="form-control" type="number" />
            </div>
            <div class="form-check form-switch mb-4">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Update</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
