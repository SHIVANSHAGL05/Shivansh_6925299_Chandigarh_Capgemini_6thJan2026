<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        :root { --primary: #1a3a5c; --accent: #c8830a; }
        body  { background: #f4f6f9; font-family: 'Segoe UI', sans-serif; }

        .sidebar {
            width: 230px; min-height: 100vh; background: var(--primary);
            position: fixed; top: 0; left: 0; z-index: 100;
            display: flex; flex-direction: column;
        }
        .sidebar-brand { padding: 22px 18px 14px; border-bottom: 1px solid rgba(255,255,255,.1); }
        .sidebar-brand h5 { color: var(--accent); font-weight: 700; font-size: .95rem; margin: 0; }
        .sidebar-brand small { color: rgba(255,255,255,.45); font-size: .68rem; }
        .sidebar-nav { padding: 14px 0; }
        .nav-label { color: rgba(255,255,255,.35); font-size:.62rem; font-weight:700;
                     letter-spacing:1.1px; text-transform:uppercase; padding:10px 18px 4px; }
        .sidebar .nav-link { color:rgba(255,255,255,.72); padding:8px 18px; font-size:.85rem;
                             display:flex; align-items:center; gap:9px; transition:all .18s; }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active { color:#fff; background:rgba(255,255,255,.1);
                                    border-left:3px solid var(--accent); padding-left:15px; }
        .sidebar .nav-link i { font-size:.95rem; width:17px; }

        .main-content { margin-left: 230px; min-height: 100vh; }
        .topbar { background:#fff; height:54px; border-bottom:1px solid #e2e8f0;
                  display:flex; align-items:center; padding:0 26px;
                  position:sticky; top:0; z-index:99; box-shadow:0 1px 4px rgba(0,0,0,.05); }
        .topbar .page-title { font-size:.95rem; font-weight:600; color:var(--primary); margin:0; }
        .content-area { padding: 26px; }

        .card { border:none; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,.07); }
        .card-header { background:var(--primary); color:#fff;
                       border-radius:10px 10px 0 0 !important; font-weight:600; padding:13px 18px; }
        .table thead th { background:var(--primary); color:#fff; font-weight:500;
                          font-size:.82rem; border:none; }
        .table tbody tr:hover { background:#eef3fb; }
        .table td { vertical-align:middle; font-size:.875rem; }
        .btn-primary { background:var(--primary); border-color:var(--primary); }
        .btn-primary:hover { background:#122845; border-color:#122845; }
        .form-label { font-weight:500; font-size:.875rem; color:#374151; }
        .form-control:focus, .form-select:focus { border-color:var(--primary);
            box-shadow:0 0 0 .2rem rgba(26,58,92,.15); }
        .badge-available   { background:#d4edda; color:#155724; padding:4px 10px;
                             border-radius:20px; font-size:.75rem; font-weight:600; }
        .badge-unavailable { background:#f8d7da; color:#721c24; padding:4px 10px;
                             border-radius:20px; font-size:.75rem; font-weight:600; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="sidebar-brand">
        <h5><i class="bi bi-book-half me-2"></i>LibraryMS</h5>
        <small>Repository Pattern Demo</small>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-label">Books</div>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
           asp-controller="Books" asp-action="Index">
            <i class="bi bi-journals"></i> All Books
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
           asp-controller="Books" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Add Book
        </a>
        <div class="nav-label">Browse</div>
        <a class="nav-link" asp-controller="Books" asp-action="Index"
           asp-route-genre="Programming">
            <i class="bi bi-code-slash"></i> Programming
        </a>
        <a class="nav-link" asp-controller="Books" asp-action="Index"
           asp-route-genre="Web Development">
            <i class="bi bi-globe"></i> Web Development
        </a>
        <a class="nav-link" asp-controller="Books" asp-action="Index"
           asp-route-genre="Software Architecture">
            <i class="bi bi-diagram-3"></i> Architecture
        </a>
    </nav>
</div>

<div class="main-content">
    <div class="topbar">
        <h6 class="page-title">@(ViewData["Title"] ?? "Library Management")</h6>
    </div>
    <div class="content-area">
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
