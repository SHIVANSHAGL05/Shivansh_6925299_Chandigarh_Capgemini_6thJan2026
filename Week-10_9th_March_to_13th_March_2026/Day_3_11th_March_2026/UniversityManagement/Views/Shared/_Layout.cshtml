<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        :root {
            --primary: #1a3a5c;
            --accent:  #e8a020;
            --light-bg: #f4f6f9;
        }

        body { background-color: var(--light-bg); font-family: 'Segoe UI', sans-serif; }

        /* Sidebar */
        .sidebar {
            width: 240px; min-height: 100vh;
            background: var(--primary);
            position: fixed; top: 0; left: 0;
            display: flex; flex-direction: column;
            z-index: 100;
        }
        .sidebar-brand {
            padding: 24px 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar-brand h5 {
            color: var(--accent); font-weight: 700;
            font-size: 1rem; margin: 0; letter-spacing: 0.5px;
        }
        .sidebar-brand small { color: rgba(255,255,255,0.5); font-size: 0.72rem; }
        .sidebar-nav { padding: 16px 0; flex: 1; }
        .nav-section-label {
            color: rgba(255,255,255,0.35);
            font-size: 0.65rem; font-weight: 700;
            letter-spacing: 1.2px; text-transform: uppercase;
            padding: 12px 20px 4px;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.75);
            padding: 9px 20px; font-size: 0.875rem;
            display: flex; align-items: center; gap: 10px;
            transition: all 0.2s;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff; background: rgba(255,255,255,0.1);
            border-left: 3px solid var(--accent);
            padding-left: 17px;
        }
        .sidebar .nav-link i { font-size: 1rem; width: 18px; }

        /* Main content */
        .main-content { margin-left: 240px; min-height: 100vh; }

        /* Topbar */
        .topbar {
            background: #fff; height: 56px;
            border-bottom: 1px solid #e2e8f0;
            display: flex; align-items: center;
            padding: 0 28px; position: sticky; top: 0; z-index: 99;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }
        .topbar .page-title {
            font-size: 1rem; font-weight: 600;
            color: var(--primary); margin: 0;
        }

        /* Content area */
        .content-area { padding: 28px; }

        /* Cards */
        .card { border: none; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.07); }
        .card-header {
            background: var(--primary); color: #fff;
            border-radius: 10px 10px 0 0 !important;
            font-weight: 600; padding: 14px 20px;
        }

        /* Tables */
        .table thead th {
            background: var(--primary); color: #fff;
            font-weight: 500; font-size: 0.825rem;
            letter-spacing: 0.3px; border: none;
        }
        .table tbody tr:hover { background-color: #eef3fb; }
        .table td { vertical-align: middle; font-size: 0.875rem; }

        /* Buttons */
        .btn-primary   { background: var(--primary); border-color: var(--primary); }
        .btn-primary:hover { background: #122845; border-color: #122845; }
        .btn-accent    { background: var(--accent); border-color: var(--accent); color: #fff; }

        /* Badges */
        .grade-badge {
            display: inline-block; padding: 3px 10px;
            border-radius: 20px; font-size: 0.75rem; font-weight: 600;
        }
        .grade-A { background: #d4edda; color: #155724; }
        .grade-B { background: #cce5ff; color: #004085; }
        .grade-C { background: #fff3cd; color: #856404; }
        .grade-D { background: #fde8d8; color: #7d3c00; }
        .grade-F { background: #f8d7da; color: #721c24; }
        .grade-pending { background: #e2e8f0; color: #4a5568; }

        /* Forms */
        .form-label { font-weight: 500; font-size: 0.875rem; color: #374151; }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(26,58,92,0.15);
        }

        /* Detail list */
        dt { color: #6b7280; font-weight: 500; font-size: 0.825rem; }
        dd { font-weight: 500; color: #111827; }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <h5><i class="bi bi-mortarboard-fill me-2"></i>UniManage</h5>
            <small>University Management System</small>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-house"></i> Dashboard
            </a>

            <div class="nav-section-label">Academic</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Students" ? "active" : "")"
               asp-controller="Students" asp-action="Index">
                <i class="bi bi-people"></i> Students
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Courses" ? "active" : "")"
               asp-controller="Courses" asp-action="Index">
                <i class="bi bi-book"></i> Courses
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Enrollments" ? "active" : "")"
               asp-controller="Enrollments" asp-action="Index">
                <i class="bi bi-journal-check"></i> Enrollments
            </a>

            <div class="nav-section-label">Administration</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Instructors" ? "active" : "")"
               asp-controller="Instructors" asp-action="Index">
                <i class="bi bi-person-badge"></i> Instructors
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "active" : "")"
               asp-controller="Departments" asp-action="Index">
                <i class="bi bi-building"></i> Departments
            </a>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="topbar">
            <h6 class="page-title">@(ViewData["Title"] ?? "Dashboard")</h6>
        </div>
        <div class="content-area">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
