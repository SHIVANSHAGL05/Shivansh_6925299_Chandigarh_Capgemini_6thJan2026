@model IEnumerable<ECommerceOMS.Models.Order>
@using ECommerceOMS.Models
@{
    ViewData["Title"] = "Orders";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-cart me-2"></i>Orders</h1>
            <p class="mb-0 opacity-75">All customer orders</p>
        </div>
        <a asp-action="Create" class="btn btn-warning fw-semibold">
            <i class="bi bi-cart-plus me-1"></i>New Order
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-3 p-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small fw-semibold text-muted">Search</label>
            <input type="text" name="search" class="form-control form-control-sm" placeholder="Order # or customer…" value="@ViewBag.Search" />
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold text-muted">Status</label>
            <select name="status" class="form-select form-select-sm">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<OrderStatus>())
                {
                    <option value="@s" selected="@(ViewBag.SelectedStatus == s.ToString())">@s</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">Clear</a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th class="text-center">Items</th>
                        <th class="text-end">Total</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Shipping</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-primary small">@o.OrderNumber</td>
                            <td class="small">@o.Customer?.FullName</td>
                            <td class="small text-muted">@o.OrderDate.ToString("dd MMM yyyy")</td>
                            <td class="text-center small">@o.OrderItems.Count</td>
                            <td class="text-end fw-semibold">₹@o.TotalAmount.ToString("N2")</td>
                            <td class="text-center">
                                @{
                                    var sc = o.Status.ToString().ToLower();
                                }
                                <span class="badge badge-@sc">@o.Status</span>
                            </td>
                            <td class="text-center small">
                                @if (o.ShippingDetail != null)
                                {
                                    <span class="text-muted">@o.ShippingDetail.Status</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (o.Status != OrderStatus.Cancelled && o.Status != OrderStatus.Delivered)
                                {
                                    <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-cart-x display-3 opacity-25"></i>
                <p class="mt-2">No orders found.</p>
            </div>
        }
    </div>
    <div class="card-footer text-muted small">
        Total: @Model.Count() orders
    </div>
</div>
