@{
    ViewData["Title"] = "Contact";
}

<div class="page-header-band">
    <div class="container">
        <h1 class="page-title">Get in Touch</h1>
        <p class="page-subtitle text-muted">We'd love to hear from you.</p>
    </div>
</div>

<div class="container py-6">
    <div class="row g-5 justify-content-center">

        <!-- Contact form -->
        <div class="col-lg-6">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
                </div>
            }

            <div class="dark-card p-5">
                <h4 class="text-white mb-4">Send us a message</h4>
                <form method="post" action="/Contact">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="filter-label">Your Name</label>
                        <input type="text" class="form-control dark-input" name="name"
                               placeholder="John Doe" required />
                    </div>
                    <div class="mb-4">
                        <label class="filter-label">Email Address</label>
                        <input type="email" class="form-control dark-input" name="email"
                               placeholder="john@example.com" required />
                    </div>
                    <div class="mb-4">
                        <label class="filter-label">Message</label>
                        <textarea class="form-control dark-input" name="message" rows="5"
                                  placeholder="How can we help?" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-accent w-100">
                        <i class="bi bi-send me-2"></i>Send Message
                    </button>
                </form>
            </div>
        </div>

        <!-- Info -->
        <div class="col-lg-4">
            <div class="contact-info-block">
                <h5 class="text-white mb-4">Contact Info</h5>
                <div class="contact-item">
                    <i class="bi bi-envelope-fill text-accent"></i>
                    <div>
                        <div class="text-white">Email</div>
                        <small class="text-muted">support@nexusstore.com</small>
                    </div>
                </div>
                <div class="contact-item">
                    <i class="bi bi-telephone-fill text-accent"></i>
                    <div>
                        <div class="text-white">Phone</div>
                        <small class="text-muted">+1 (800) 123-4567</small>
                    </div>
                </div>
                <div class="contact-item">
                    <i class="bi bi-clock-fill text-accent"></i>
                    <div>
                        <div class="text-white">Support Hours</div>
                        <small class="text-muted">Mon–Fri, 9am–6pm EST</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
