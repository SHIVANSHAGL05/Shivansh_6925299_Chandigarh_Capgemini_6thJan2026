@model ECommerceOMS.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card p-4 text-center">
            <div class="product-img-placeholder rounded mb-3" style="height:220px;">
                <i class="bi bi-box-seam" style="font-size:5rem;"></i>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <div class="d-flex gap-2 justify-content-center">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                </div>
            }
        </div>
    </div>
    <div class="col-md-8">
        <div class="card p-4">
            <span class="badge bg-primary-subtle text-primary mb-2">@Model.Category?.Name</span>
            <h2 class="fw-bold">@Model.Name</h2>
            @if (Model.SKU != null)
            {
                <p class="text-muted small mb-2"><i class="bi bi-upc me-1"></i>SKU: @Model.SKU</p>
            }
            <hr>
            <p>@Model.Description</p>
            <div class="row g-3 mt-1">
                <div class="col-sm-4">
                    <div class="bg-soft-primary rounded p-3 text-center">
                        <div class="text-muted small">Price</div>
                        <div class="fs-4 fw-bold text-primary">₹@Model.Price.ToString("N2")</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="bg-soft-primary rounded p-3 text-center">
                        <div class="text-muted small">Stock</div>
                        <div class="fs-4 fw-bold @(Model.StockQuantity > 10 ? "text-success" : Model.StockQuantity > 0 ? "text-warning" : "text-danger")">
                            @Model.StockQuantity
                        </div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="bg-soft-primary rounded p-3 text-center">
                        <div class="text-muted small">Status</div>
                        <div class="mt-1">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="mt-3 text-muted small">
                <i class="bi bi-calendar me-1"></i>Added: @Model.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")
            </div>
            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary me-2">
                    <i class="bi bi-arrow-left me-1"></i>Back
                </a>
                <a asp-controller="Order" asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-cart-plus me-1"></i>Place Order
                </a>
            </div>
        </div>
    </div>
</div>
