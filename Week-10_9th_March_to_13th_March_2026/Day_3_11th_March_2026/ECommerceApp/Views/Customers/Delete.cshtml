@model ECommerceApp.Models.Customer

@{
    ViewData["Title"] = "Delete Customer";
}

<h1>Delete Customer</h1>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete <strong>@Model.FullName</strong>?
    This will also delete all their orders.
</div>

<div class="card" style="max-width:400px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.FullName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Orders</dt>
            <dd class="col-sm-8">@Model.Orders.Count order(s) will be deleted</dd>
        </dl>

        <form method="post" action="/Customers/Delete/@Model.CustomerId">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a href="/Customers/Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>