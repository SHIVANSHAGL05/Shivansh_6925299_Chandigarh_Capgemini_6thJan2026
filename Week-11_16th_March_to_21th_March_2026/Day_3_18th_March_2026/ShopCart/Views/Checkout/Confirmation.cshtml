@model ShopCart.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
}

<!-- Progress Bar — Step 4 complete -->
<div class="mb-4">
    <div class="d-flex justify-content-between small text-muted mb-1">
        <span>1. Cart</span>
        <span>2. Address</span>
        <span>3. Payment</span>
        <span class="fw-bold text-success">4. Done ✓</span>
    </div>
    <div class="progress" style="height: 8px;">
        <div class="progress-bar bg-success" style="width: 100%;"></div>
    </div>
</div>

<!-- Success Alert -->
<div class="alert alert-success d-flex align-items-center gap-3 mb-4">
    <i class="bi bi-check-circle-fill fs-3"></i>
    <div>
        <strong>Order Placed Successfully!</strong><br />
        Your order reference is <strong>@Model.OrderRef</strong>. Thank you, @Model.FullName!
    </div>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white d-flex justify-content-between">
                <span><i class="bi bi-receipt me-2"></i>Order Receipt</span>
                <strong>@Model.OrderRef</strong>
            </div>
            <div class="card-body">

                <!-- Delivery Info -->
                <h6 class="text-muted text-uppercase mb-3">Delivery To</h6>
                <div class="row mb-4">
                    <div class="col-sm-3 text-muted">Name</div>
                    <div class="col-sm-9">@Model.FullName</div>
                    <div class="col-sm-3 text-muted">Email</div>
                    <div class="col-sm-9">@Model.Email</div>
                    <div class="col-sm-3 text-muted">Phone</div>
                    <div class="col-sm-9">@Model.Phone</div>
                    <div class="col-sm-3 text-muted">Address</div>
                    <div class="col-sm-9">@Model.Address, @Model.City — @Model.PinCode</div>
                </div>

                <hr />

                <!-- Items Ordered -->
                <h6 class="text-muted text-uppercase mb-3">Items Ordered</h6>
                <table class="table table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">₹@item.Subtotal.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="2">Total</td>
                            <td class="text-end text-success">₹@Model.Total.ToString("N0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="card-footer d-flex gap-2">
                <a href="/Shop" class="btn btn-dark">
                    <i class="bi bi-bag me-2"></i>Continue Shopping
                </a>
            </div>
        </div>
    </div>
</div>
