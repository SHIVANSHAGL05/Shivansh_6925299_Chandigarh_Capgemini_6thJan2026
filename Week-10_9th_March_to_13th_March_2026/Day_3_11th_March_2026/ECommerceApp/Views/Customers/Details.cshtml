@model ECommerceApp.Models.Customer

@{
    ViewData["Title"] = "Customer Details";
}

<h1>Customer Details</h1>
<hr />

<div class="card" style="max-width:700px;">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">@Model.FullName</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Customer ID</dt>
            <dd class="col-sm-8">@Model.CustomerId</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">@Model.Address</dd>
        </dl>

        <h5 class="mt-3">Order History</h5>
        @if (Model.Orders.Any())
        {
            @foreach (var order in Model.Orders)
            {
                <div class="card mb-3 border-secondary">
                    <div class="card-header d-flex justify-content-between">
                        <span>Order #@order.OrderId — @order.OrderDate.ToString("MMM dd, yyyy")</span>
                        <span class="fw-bold text-success">₹@order.TotalAmount.ToString("N0")</span>
                    </div>
                    <div class="card-body p-2">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Qty</th>
                                    <th>Unit Price</th>
                                    <th>Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in order.OrderDetails)
                                {
                                    <tr>
                                        <td>@detail.Product?.Name</td>
                                        <td>@detail.Quantity</td>
                                        <td>₹@detail.UnitPrice.ToString("N0")</td>
                                        <td>₹@((detail.UnitPrice * detail.Quantity).ToString("N0"))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer text-end">
                        <a href="/Orders/Summary/@order.OrderId" class="btn btn-info btn-sm">View Summary</a>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted">No orders placed yet.</p>
        }
    </div>
    <div class="card-footer">
        <a href="/Customers/Index" class="btn btn-secondary">Back</a>
        <a href="/Customers/Edit/@Model.CustomerId" class="btn btn-warning ms-2">Edit</a>
    </div>
</div>