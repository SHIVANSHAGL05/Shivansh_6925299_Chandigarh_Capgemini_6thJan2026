@model PatientDto
@{
    ViewData["Title"] = $"Patient — {Model.FullName}";
}

<div class="mb-3">
    <a asp-action="Patients" class="text-decoration-none text-muted small">
        <i class="bi bi-arrow-left me-1"></i>Back to Patients
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body text-center p-4">
                <div class="avatar-circle-lg bg-primary text-white mx-auto mb-3">@Model.FullName[0]</div>
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <p class="text-muted mb-2 small">@Model.Email</p>
                <p class="text-muted small mb-0">@(Model.PhoneNumber ?? "No phone")</p>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold text-muted text-uppercase small mb-3">Health Summary</h6>
                <div class="d-flex justify-content-between border-bottom py-2">
                    <span class="text-muted small">Blood Group</span>
                    <strong class="text-danger">@(Model.BloodGroup ?? "—")</strong>
                </div>
                <div class="d-flex justify-content-between border-bottom py-2">
                    <span class="text-muted small">Weight</span>
                    <strong>@(Model.Weight.HasValue ? $"{Model.Weight:0.0} kg" : "—")</strong>
                </div>
                <div class="d-flex justify-content-between border-bottom py-2">
                    <span class="text-muted small">Height</span>
                    <strong>@(Model.Height.HasValue ? $"{Model.Height:0} cm" : "—")</strong>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted small">Registered</span>
                    <strong>@Model.CreatedAt.ToString("dd MMM yyyy")</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        @if (!string.IsNullOrEmpty(Model.AllergiesNotes))
        {
            <div class="card border-0 shadow-sm mb-4 border-start border-danger border-4">
                <div class="card-body">
                    <h6 class="fw-semibold text-danger mb-2">
                        <i class="bi bi-exclamation-triangle me-2"></i>Allergies
                    </h6>
                    <p class="mb-0">@Model.AllergiesNotes</p>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.MedicalHistory))
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-medical text-primary me-2"></i>Medical History</h6>
                </div>
                <div class="card-body"><p class="mb-0">@Model.MedicalHistory</p></div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.EmergencyContactName))
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-telephone-fill text-warning me-2"></i>Emergency Contact</h6>
                </div>
                <div class="card-body">
                    <div class="fw-semibold">@Model.EmergencyContactName</div>
                    <div class="text-muted">@(Model.EmergencyContactPhone ?? "—")</div>
                </div>
            </div>
        }
    </div>
</div>
