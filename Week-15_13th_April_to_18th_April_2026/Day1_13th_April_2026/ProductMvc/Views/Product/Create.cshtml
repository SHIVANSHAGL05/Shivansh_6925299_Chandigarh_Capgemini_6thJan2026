@model ProductMvc.Models.Product

@{
    ViewData["Title"] = "Create Product";
}

<h2>Create Product</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="mt-4">
    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Product Name</label>
        <input asp-for="Name" class="form-control" required placeholder="Enter product name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Price" class="form-label">Price</label>
        <input asp-for="Price" type="number" step="0.01" min="0.01" class="form-control" required placeholder="Enter price" />
        <small class="form-text text-muted">Must be greater than 0</small>
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ImageFile" class="form-label">Product Image</label>
        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" required />
        <small class="form-text text-muted">Image file is required</small>
        <span asp-validation-for="ImageFile" class="text-danger"></span>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Save Product</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
