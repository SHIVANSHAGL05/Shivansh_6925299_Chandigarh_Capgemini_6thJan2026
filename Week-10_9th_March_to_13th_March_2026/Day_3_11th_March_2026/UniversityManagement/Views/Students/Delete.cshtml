@model UniversityManagement.Models.Student
@{
    ViewData["Title"] = "Delete Student";
}

<h2 class="text-danger">Delete Student</h2>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete this student? This will also remove all their enrollments.
</div>

<dl class="row">
    <dt class="col-sm-3">Full Name</dt>
    <dd class="col-sm-9">@Model.FullName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Enrollment Date</dt>
    <dd class="col-sm-9">@Model.EnrollmentDate.ToShortDateString()</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="StudentId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>