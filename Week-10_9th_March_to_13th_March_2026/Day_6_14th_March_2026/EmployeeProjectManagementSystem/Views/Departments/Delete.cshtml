@model EmployeeProjectManagementSystem.Models.Department

@{
    ViewData["Title"] = "Delete Department";
}

<h2>Delete Department</h2>
<p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>

@if (Model.Employees.Any())
{
    <p style="color:red;">Warning: This department has @Model.Employees.Count employee(s). Deleting it will affect them.</p>
}

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit">Delete</button>
    <a asp-action="Index">Cancel</a>
</form>
