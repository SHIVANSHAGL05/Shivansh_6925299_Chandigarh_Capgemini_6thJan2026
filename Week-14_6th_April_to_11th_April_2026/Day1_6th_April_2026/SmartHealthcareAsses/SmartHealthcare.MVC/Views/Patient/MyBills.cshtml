@model List<SmartHealthcare.Core.DTOs.BillDto>
@{
    ViewData["Title"] = "My Bills";
    var totalUnpaid = Model.Where(b => b.PaymentStatus == "Unpaid").Sum(b => b.TotalAmount);
    var totalPaid   = Model.Where(b => b.PaymentStatus == "Paid").Sum(b => b.TotalAmount);
}

<div class="page-header">
    <div>
        <h4><i class="bi bi-receipt-cutoff me-2 text-teal"></i>My Bills &amp; Payments</h4>
        <p class="text-muted mb-0 small">View and pay your outstanding medical bills</p>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card stat-rose border-0 shadow-sm">
            <div class="stat-icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-clock-fill"></i></div>
            <div class="stat-number text-danger">₹@totalUnpaid.ToString("0")</div>
            <div class="stat-label">Outstanding Balance</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card stat-green border-0 shadow-sm">
            <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-check-circle-fill"></i></div>
            <div class="stat-number" style="color:var(--sc-green)">₹@totalPaid.ToString("0")</div>
            <div class="stat-label">Total Paid</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm">
            <div class="stat-icon" style="background:#e0f9f8;color:var(--sc-teal)"><i class="bi bi-receipt"></i></div>
            <div class="stat-number text-navy">@Model.Count</div>
            <div class="stat-label">Total Bills</div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body empty-state">
            <i class="bi bi-receipt"></i>
            <p class="fw-600">No bills found</p>
            <p class="text-muted small">Your billing history will appear here after appointments.</p>
        </div>
    </div>
}
else
{
    @foreach (var bill in Model)
    {
        <div class="card border-0 shadow-sm mb-3 bill-card @(bill.PaymentStatus == "Paid" ? "paid" : "unpaid")">
            <div class="card-body">
                <div class="row align-items-center g-3">
                    <div class="col-md-5">
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                                 style="width:48px;height:48px;background:@(bill.PaymentStatus=="Paid"?"#dcfce7":"#fee2e2")">
                                <i class="bi @(bill.PaymentStatus=="Paid"?"bi-check-circle-fill":"bi-clock-fill")" 
                                   style="color:@(bill.PaymentStatus=="Paid"?"var(--sc-green)":"var(--sc-rose)");font-size:1.3rem;"></i>
                            </div>
                            <div>
                                <div class="fw-700 text-navy" style="font-family:'Outfit',sans-serif">Bill #@bill.Id</div>
                                <div class="text-muted small"><i class="bi bi-calendar3 me-1"></i>@bill.AppointmentDate.ToString("dd MMM yyyy")</div>
                                <div class="text-muted small"><i class="bi bi-person-badge me-1"></i>Dr. @bill.DoctorName</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="row text-center g-2">
                            <div class="col">
                                <div class="text-muted" style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px">Consultation</div>
                                <div class="fw-600 small">₹@bill.ConsultationFee.ToString("0.00")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted" style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px">Medicines</div>
                                <div class="fw-600 small">₹@bill.MedicineCharges.ToString("0.00")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted" style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px">Total</div>
                                <div class="bill-amount" style="font-size:1.1rem">₹@bill.TotalAmount.ToString("0")</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 text-md-end d-flex flex-column align-items-md-end gap-2">
                        @if (bill.PaymentStatus == "Paid")
                        {
                            <span class="badge bg-success fs-7"><i class="bi bi-check-circle me-1"></i>Paid</span>
                            <button class="btn btn-outline-secondary btn-sm" 
                                    onclick="showReceipt(@bill.Id, '@bill.DoctorName', '@bill.AppointmentDate.ToString("dd MMM yyyy")', @bill.ConsultationFee, @bill.MedicineCharges, @bill.TotalAmount)">
                                <i class="bi bi-download me-1"></i>Receipt
                            </button>
                        }
                        else
                        {
                            <span class="badge bg-danger"><i class="bi bi-exclamation-circle me-1"></i>Unpaid</span>
                            <button class="btn btn-pay btn-sm" 
                                    onclick="openPayment(@bill.Id, @bill.TotalAmount, 'Dr. @bill.DoctorName', '@bill.AppointmentDate.ToString("dd MMM yyyy")')">
                                <i class="bi bi-credit-card me-1"></i>Pay ₹@bill.TotalAmount.ToString("0")
                            </button>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(bill.Notes))
                {
                    <div class="mt-3 pt-3 border-top">
                        <small class="text-muted"><i class="bi bi-sticky me-1"></i>@bill.Notes</small>
                    </div>
                }
            </div>
        </div>
    }
}

<!-- ── Payment Modal ──────────────────────────────────────────────── -->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-shield-lock me-2"></i>Secure Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <!-- Summary -->
                <div class="payment-summary">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div style="opacity:.7;font-size:.8rem;letter-spacing:.5px;text-transform:uppercase">Amount Due</div>
                            <div class="amount-display" id="payAmountDisplay">₹0</div>
                        </div>
                        <div class="text-end" style="opacity:.8;font-size:.85rem">
                            <div id="payDoctorDisplay"></div>
                            <div id="payDateDisplay"></div>
                        </div>
                    </div>
                </div>

                <!-- Payment Methods -->
                <div class="mb-4">
                    <div class="form-label mb-2">Choose Payment Method</div>
                    <div class="pay-method-card selected" id="method-card" onclick="selectMethod('card')">
                        <div class="pay-method-icon" style="background:#eff6ff;"><i class="bi bi-credit-card-2-front" style="color:#3b82f6"></i></div>
                        <div>
                            <div class="fw-600">Debit / Credit Card</div>
                            <div class="text-muted small">Visa, Mastercard, RuPay</div>
                        </div>
                        <i class="bi bi-check-circle-fill ms-auto text-teal" id="check-card"></i>
                    </div>
                    <div class="pay-method-card" id="method-upi" onclick="selectMethod('upi')">
                        <div class="pay-method-icon" style="background:#fdf4ff;"><i class="bi bi-phone" style="color:#a855f7"></i></div>
                        <div>
                            <div class="fw-600">UPI</div>
                            <div class="text-muted small">PhonePe, GPay, Paytm</div>
                        </div>
                        <i class="bi bi-circle ms-auto text-muted" id="check-upi"></i>
                    </div>
                    <div class="pay-method-card" id="method-netbanking" onclick="selectMethod('netbanking')">
                        <div class="pay-method-icon" style="background:#fff7ed;"><i class="bi bi-bank" style="color:#f97316"></i></div>
                        <div>
                            <div class="fw-600">Net Banking</div>
                            <div class="text-muted small">All major banks</div>
                        </div>
                        <i class="bi bi-circle ms-auto text-muted" id="check-netbanking"></i>
                    </div>
                </div>

                <!-- Card Fields (shown for card method) -->
                <div id="cardFields">
                    <div class="mb-3">
                        <label class="form-label">Card Number</label>
                        <div class="position-relative">
                            <input type="text" id="cardNumber" class="form-control" placeholder="1234 5678 9012 3456" maxlength="19" />
                            <i class="bi bi-credit-card position-absolute" style="right:12px;top:50%;transform:translateY(-50%);color:var(--sc-muted)"></i>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-7">
                            <label class="form-label">Expiry Date</label>
                            <input type="text" id="cardExpiry" class="form-control" placeholder="MM / YY" maxlength="7" />
                        </div>
                        <div class="col-5">
                            <label class="form-label">CVV</label>
                            <input type="password" id="cardCvv" class="form-control" placeholder="•••" maxlength="3" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Cardholder Name</label>
                        <input type="text" id="cardName" class="form-control" placeholder="Name on card" />
                    </div>
                </div>

                <!-- UPI Fields -->
                <div id="upiFields" class="d-none">
                    <label class="form-label">UPI ID</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-at"></i></span>
                        <input type="text" id="upiId" class="form-control" placeholder="yourname@paytm" />
                    </div>
                    <div class="mt-2 text-muted small"><i class="bi bi-info-circle me-1"></i>You'll receive a payment request on your UPI app</div>
                </div>

                <!-- NetBanking Fields -->
                <div id="netFields" class="d-none">
                    <label class="form-label">Select Bank</label>
                    <select class="form-select" id="bankSelect">
                        <option value="">-- Select your bank --</option>
                        <option>SBI</option><option>HDFC Bank</option><option>ICICI Bank</option>
                        <option>Axis Bank</option><option>Kotak Mahindra</option><option>PNB</option>
                        <option>Bank of Baroda</option><option>Other</option>
                    </select>
                </div>

                <div class="mt-3 p-3 rounded-3 d-flex align-items-center gap-2" style="background:#f0fdf9;border:1px solid #a7f3d0">
                    <i class="bi bi-shield-check text-success"></i>
                    <small class="text-muted">256-bit SSL encrypted · Your data is safe</small>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 px-4 pb-4">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-pay flex-grow-1" id="payNowBtn" onclick="processPayment()">
                    <i class="bi bi-lock-fill me-2"></i>Pay Now
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Receipt Modal ──────────────────────────────────────────────── -->
<div class="modal fade" id="receiptModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="receiptContent">
            <div class="receipt-header text-center">
                <i class="bi bi-hospital-fill fs-1 mb-2 d-block" style="color:var(--sc-teal-light)"></i>
                <h5 class="fw-800 mb-1" style="font-family:'Outfit',sans-serif">SmartCare</h5>
                <div style="opacity:.6;font-size:.85rem">Payment Receipt</div>
            </div>
            <div class="card-body p-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Receipt No.</span>
                    <span class="fw-600" id="rcptId">#—</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Doctor</span>
                    <span class="fw-600" id="rcptDoctor"></span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Appointment Date</span>
                    <span class="fw-600" id="rcptDate"></span>
                </div>
                <div class="receipt-divider"></div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Consultation Fee</span>
                    <span id="rcptConsult"></span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Medicine Charges</span>
                    <span id="rcptMed"></span>
                </div>
                <div class="receipt-divider"></div>
                <div class="d-flex justify-content-between">
                    <span class="fw-700">Total Paid</span>
                    <span class="fw-800 fs-5" style="color:var(--sc-teal);font-family:'Outfit',sans-serif" id="rcptTotal"></span>
                </div>
                <div class="text-center mt-4">
                    <span class="badge bg-success px-4 py-2" style="font-size:.85rem"><i class="bi bi-check-circle-fill me-2"></i>Payment Successful</span>
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4 pt-0">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                <button class="btn btn-primary" onclick="window.print()"><i class="bi bi-printer me-2"></i>Print</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentBillId = 0;
let currentMethod = 'card';

function openPayment(billId, amount, doctor, date) {
    currentBillId = billId;
    document.getElementById('payAmountDisplay').textContent = '₹' + amount.toFixed(0);
    document.getElementById('payDoctorDisplay').textContent = doctor;
    document.getElementById('payDateDisplay').textContent = date;
    document.getElementById('payNowBtn').innerHTML = '<i class="bi bi-lock-fill me-2"></i>Pay ₹' + amount.toFixed(0);
    selectMethod('card');
    new bootstrap.Modal(document.getElementById('paymentModal')).show();
}

function selectMethod(m) {
    currentMethod = m;
    ['card','upi','netbanking'].forEach(id => {
        const card  = document.getElementById('method-' + id);
        const check = document.getElementById('check-' + id);
        if (id === m) {
            card.classList.add('selected');
            check.className = 'bi bi-check-circle-fill ms-auto text-teal';
        } else {
            card.classList.remove('selected');
            check.className = 'bi bi-circle ms-auto text-muted';
        }
    });
    document.getElementById('cardFields').classList.toggle('d-none', m !== 'card');
    document.getElementById('upiFields').classList.toggle('d-none',  m !== 'upi');
    document.getElementById('netFields').classList.toggle('d-none',  m !== 'netbanking');
}

// Card number auto-format
document.getElementById('cardNumber').addEventListener('input', function() {
    let val = this.value.replace(/\D/g,'').substring(0,16);
    this.value = val.replace(/(.{4})/g,'$1 ').trim();
});
document.getElementById('cardExpiry').addEventListener('input', function() {
    let val = this.value.replace(/\D/g,'').substring(0,4);
    if (val.length >= 3) val = val.substring(0,2) + ' / ' + val.substring(2);
    this.value = val;
});

function processPayment() {
    // Validation
    if (currentMethod === 'card') {
        const num  = document.getElementById('cardNumber').value.replace(/\s/g,'');
        const exp  = document.getElementById('cardExpiry').value;
        const cvv  = document.getElementById('cardCvv').value;
        const name = document.getElementById('cardName').value.trim();
        if (num.length < 16 || !exp || cvv.length < 3 || !name) {
            showValidationError('Please fill in all card details correctly.'); return;
        }
    } else if (currentMethod === 'upi') {
        const upi = document.getElementById('upiId').value.trim();
        if (!upi.includes('@@')) { showValidationError('Please enter a valid UPI ID.'); return; }
    } else {
        if (!document.getElementById('bankSelect').value) { showValidationError('Please select a bank.'); return; }
    }

    const btn = document.getElementById('payNowBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="processing-spinner"></span>Processing...';

    // Simulate payment processing (2s)
    setTimeout(() => {
        submitPayment(currentBillId);
    }, 2000);
}

function showValidationError(msg) {
    const existing = document.querySelector('.pay-error');
    if (existing) existing.remove();
    const el = document.createElement('div');
    el.className = 'alert alert-danger pay-error mt-3';
    el.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>' + msg;
    document.getElementById('payNowBtn').closest('.modal-footer').insertAdjacentElement('beforebegin', el);
}

function submitPayment(billId) {
    fetch(`/Admin/MarkBillPaid`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
            billId: billId,
            __RequestVerificationToken: document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || ''
        })
    })
    .then(r => {
        // Even if fetch fails in demo mode, show success for demo
        const modal = bootstrap.Modal.getInstance(document.getElementById('paymentModal'));
        modal.hide();
        location.reload();
    })
    .catch(() => { location.reload(); });
}

function showReceipt(id, doctor, date, consult, med, total) {
    document.getElementById('rcptId').textContent = '#' + id;
    document.getElementById('rcptDoctor').textContent = 'Dr. ' + doctor;
    document.getElementById('rcptDate').textContent = date;
    document.getElementById('rcptConsult').textContent = '₹' + parseFloat(consult).toFixed(2);
    document.getElementById('rcptMed').textContent    = '₹' + parseFloat(med).toFixed(2);
    document.getElementById('rcptTotal').textContent  = '₹' + parseFloat(total).toFixed(2);
    new bootstrap.Modal(document.getElementById('receiptModal')).show();
}
</script>
}
<!-- Hidden CSRF form for payment submission -->
<form id="csrfForm" style="display:none">@Html.AntiForgeryToken()</form>
