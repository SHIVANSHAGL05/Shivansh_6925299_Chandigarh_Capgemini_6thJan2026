@model PrescriptionDto
@{
    ViewData["Title"] = $"Prescription #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <a asp-controller="Appointment" asp-action="Details" asp-route-id="@Model.AppointmentId"
       class="text-decoration-none text-muted small">
        <i class="bi bi-arrow-left me-1"></i>Back to Appointment
    </a>
    <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
        <i class="bi bi-printer me-1"></i>Print
    </button>
</div>

<!-- Prescription Document -->
<div class="card border-0 shadow-sm mx-auto" style="max-width:750px" id="prescriptionDoc">
    <div class="card-body p-5">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start border-bottom pb-4 mb-4">
            <div>
                <h3 class="fw-bold text-primary mb-1">
                    <i class="bi bi-hospital me-2"></i>SmartCare Hospital
                </h3>
                <div class="text-muted small">Smart Healthcare Management System</div>
            </div>
            <div class="text-end">
                <div class="fw-bold text-muted small text-uppercase">Prescription</div>
                <div class="fw-bold fs-5">#@Model.Id</div>
                <div class="text-muted small">@Model.IssuedDate.ToString("dd MMMM yyyy")</div>
                @if (Model.ValidUntil.HasValue)
                {
                    <div class="text-muted small">Valid until: @Model.ValidUntil.Value.ToString("dd MMM yyyy")</div>
                }
            </div>
        </div>

        <!-- Patient & Doctor -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="p-3 bg-light rounded-3">
                    <div class="text-muted small fw-semibold text-uppercase mb-2">Patient</div>
                    <div class="fw-bold fs-6">@Model.PatientName</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 bg-light rounded-3">
                    <div class="text-muted small fw-semibold text-uppercase mb-2">Prescribed By</div>
                    <div class="fw-bold fs-6">Dr. @Model.DoctorName</div>
                </div>
            </div>
        </div>

        <!-- Diagnosis -->
        @if (!string.IsNullOrEmpty(Model.Diagnosis))
        {
            <div class="mb-4">
                <div class="fw-semibold text-muted small text-uppercase mb-2">Diagnosis</div>
                <div class="p-3 border-start border-primary border-3 bg-light rounded-end">
                    @Model.Diagnosis
                </div>
            </div>
        }

        <!-- Medicines -->
        <div class="mb-4">
            <div class="fw-semibold text-muted small text-uppercase mb-3">
                <i class="bi bi-capsule me-2"></i>Prescribed Medicines
            </div>
            <table class="table table-bordered align-middle">
                <thead class="table-primary">
                    <tr>
                        <th>#</th>
                        <th>Medicine</th>
                        <th>Dosage</th>
                        <th>Frequency</th>
                        <th>Duration</th>
                        <th>Instructions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Medicines.Count; i++)
                    {
                        var m = Model.Medicines[i];
                        <tr>
                            <td class="text-muted small">@(i + 1)</td>
                            <td class="fw-semibold">@m.MedicineName</td>
                            <td>@m.Dosage</td>
                            <td>@m.Frequency</td>
                            <td>@m.Duration</td>
                            <td class="text-muted small">@(m.SpecialInstructions ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Instructions -->
        @if (!string.IsNullOrEmpty(Model.Instructions))
        {
            <div class="mb-4">
                <div class="fw-semibold text-muted small text-uppercase mb-2">General Instructions</div>
                <p class="mb-0">@Model.Instructions</p>
            </div>
        }

        <!-- Follow-up -->
        @if (!string.IsNullOrEmpty(Model.FollowUpNotes))
        {
            <div class="alert alert-info border-0 mb-4">
                <i class="bi bi-calendar-check me-2"></i>
                <strong>Follow-up:</strong> @Model.FollowUpNotes
            </div>
        }

        <!-- Signature -->
        <div class="d-flex justify-content-end mt-5 pt-4 border-top">
            <div class="text-center">
                <div class="border-bottom border-dark mb-1" style="width:200px;height:40px"></div>
                <div class="fw-semibold">Dr. @Model.DoctorName</div>
                <div class="text-muted small">Licensed Medical Practitioner</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            .no-print, nav, footer { display: none !important; }
            .card { box-shadow: none !important; border: 1px solid #dee2e6 !important; }
            body { background: white !important; }
        }
    </style>
}
