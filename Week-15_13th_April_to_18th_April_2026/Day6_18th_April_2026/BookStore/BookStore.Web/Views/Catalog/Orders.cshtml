@model IReadOnlyList<OrderSummaryViewModel>
@{
    ViewData["Title"] = "My Orders";
}

<section class="page-card reveal">
    <h1>My Placed Orders</h1>
    <p>Your latest order activity appears here.</p>

    @if (!Model.Any())
    {
        <p class="mt-3">No orders placed yet.</p>
    }
    else
    {
        <div class="table-wrap mt-3">
            <table>
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Ordered On (UTC)</th>
                        <th>Status</th>
                        <th>Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.OrderId</td>
                            <td>@item.OrderedOn.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="status-pill">@item.Status</span></td>
                            <td>$@item.TotalAmount.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
