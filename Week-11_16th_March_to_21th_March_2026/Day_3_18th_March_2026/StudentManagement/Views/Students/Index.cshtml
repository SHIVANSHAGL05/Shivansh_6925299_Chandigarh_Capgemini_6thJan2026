@model IEnumerable<StudentManagement.Models.Student>
@{
    ViewData["Title"] = "Students";
}

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-0 fw-bold text-dark"><i class="bi bi-people-fill text-primary me-2"></i>Student Records</h2>
        <p class="text-muted mb-0 small">Manage all enrolled students</p>
    </div>
    <button class="btn btn-primary" id="btnAddNew">
        <i class="bi bi-plus-circle me-2"></i>Add Student
    </button>
</div>

<!-- Toast container -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div id="toastContainer" class="position-fixed top-0 end-0 p-3" style="z-index:1100"></div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="display-6 fw-bold text-primary">@Model.Count()</div>
            <div class="text-muted small">Total Students</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="display-6 fw-bold text-success">@Model.Select(s => s.Course).Distinct().Count()</div>
            <div class="text-muted small">Courses</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="display-6 fw-bold text-info">@Model.Count(s => s.JoiningDate.Year == DateTime.Now.Year)</div>
            <div class="text-muted small">Joined This Year</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="display-6 fw-bold text-warning">@Model.Count(s => s.JoiningDate >= DateTime.Now.AddMonths(-3))</div>
            <div class="text-muted small">Recent (3 months)</div>
        </div>
    </div>
</div>

<!-- Search / Filter bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-2 align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="searchInput" class="form-control border-start-0" placeholder="Search by name, email, or course…" />
                </div>
            </div>
            <div class="col-md-4">
                <select id="courseFilter" class="form-select">
                    <option value="">All Courses</option>
                    @foreach (var course in Model.Select(s => s.Course).Distinct().OrderBy(c => c))
                    {
                        <option value="@course">@course</option>
                    }
                </select>
            </div>
            <div class="col-md-2 text-md-end">
                <span id="rowCount" class="text-muted small">@Model.Count() records</span>
            </div>
        </div>
    </div>
</div>

<!-- Students Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="studentsTable">
                <thead class="table-primary">
                    <tr>
                        <th class="ps-4">#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Course</th>
                        <th>Joining Date</th>
                        <th class="text-center pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{int rowNum = 1;}
                    @foreach (var student in Model)
                    {
                        <tr data-name="@student.Name.ToLower()"
                            data-email="@student.Email.ToLower()"
                            data-course="@student.Course">
                            <td class="ps-4 text-muted small">@rowNum</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-circle bg-primary text-white">
                                        @student.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-semibold">@student.Name</span>
                                </div>
                            </td>
                            <td class="text-muted">@student.Email</td>
                            <td><span class="badge bg-light text-dark border fw-normal">@student.Course</span></td>
                            <td>@student.JoiningDate.ToString("dd MMM yyyy")</td>
                            <td class="text-center pe-4">
                                <button class="btn btn-sm btn-outline-primary me-1 btn-edit"
                                        data-id="@student.Id"
                                        title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-delete"
                                        data-id="@student.Id"
                                        data-name="@student.Name"
                                        title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                        rowNum++;
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox display-4"></i>
                <p class="mt-3">No students found. Click <strong>Add Student</strong> to get started.</p>
            </div>
        }
    </div>
</div>

<!-- =====================================================================
     ADD / EDIT MODAL
     ===================================================================== -->
<div class="modal fade" id="studentModal" tabindex="-1" aria-labelledby="studentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-semibold" id="studentModalLabel">
                    <i class="bi bi-person-plus-fill me-2"></i><span id="modalTitleText">Add New Student</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="studentForm" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="studentId" name="Id" value="0" />

                    <div class="row g-3">
                        <!-- Name -->
                        <div class="col-md-6">
                            <label for="inputName" class="form-label fw-semibold">
                                Full Name <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input type="text" class="form-control" id="inputName" name="Name"
                                       placeholder="e.g. Aarav Sharma" required minlength="2" maxlength="100" />
                            </div>
                            <div class="invalid-feedback" id="nameError"></div>
                        </div>

                        <!-- Email -->
                        <div class="col-md-6">
                            <label for="inputEmail" class="form-label fw-semibold">
                                Email Address <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" class="form-control" id="inputEmail" name="Email"
                                       placeholder="e.g. aarav@example.com" required maxlength="150" />
                            </div>
                            <div class="invalid-feedback" id="emailError"></div>
                        </div>

                        <!-- Course -->
                        <div class="col-md-6">
                            <label for="inputCourse" class="form-label fw-semibold">
                                Course <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-book"></i></span>
                                <input type="text" class="form-control" id="inputCourse" name="Course"
                                       placeholder="e.g. Full Stack Development" required maxlength="100"
                                       list="courseList" />
                                <datalist id="courseList">
                                    <option value="Full Stack Development" />
                                    <option value="Data Science" />
                                    <option value="Cloud Computing" />
                                    <option value="UI/UX Design" />
                                    <option value="Cybersecurity" />
                                    <option value="DevOps Engineering" />
                                    <option value="Mobile App Development" />
                                    <option value="Machine Learning" />
                                </datalist>
                            </div>
                            <div class="invalid-feedback" id="courseError"></div>
                        </div>

                        <!-- Joining Date -->
                        <div class="col-md-6">
                            <label for="inputJoiningDate" class="form-label fw-semibold">
                                Joining Date <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                                <input type="date" class="form-control" id="inputJoiningDate" name="JoiningDate" required />
                            </div>
                            <div class="invalid-feedback" id="joiningDateError"></div>
                        </div>
                    </div>

                    <!-- Server-side error summary -->
                    <div id="formErrorSummary" class="alert alert-danger mt-3 d-none"></div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-primary" id="btnSaveStudent">
                    <i class="bi bi-floppy me-1"></i>Save Student
                </button>
            </div>
        </div>
    </div>
</div>

<!-- DELETE CONFIRMATION MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-semibold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you sure you want to delete <strong id="deleteStudentName"></strong>? This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0">
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmDelete">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/students.js"></script>
}
