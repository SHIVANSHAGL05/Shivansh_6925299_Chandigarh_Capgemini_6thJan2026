@model EmployeeProjectManagementSystem.Models.Project

@{
    ViewData["Title"] = "Edit Project";
    var assignedIds = ViewBag.AssignedEmployeeIds as List<int> ?? new List<int>();
}

<h2>Edit Project</h2>

<form asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />
    <div>
        <label asp-for="Title"></label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>
    <div>
        <label asp-for="Description"></label>
        <input asp-for="Description" />
    </div>
    <div>
        <label>Assign Employees</label>
        @foreach (var employee in ViewBag.Employees)
        {
            <div>
                <input type="checkbox" name="selectedEmployees" value="@employee.Id"
                       @(assignedIds.Contains(employee.Id) ? "checked" : "") />
                @employee.Name (@employee.Department?.Name)
            </div>
        }
    </div>
    <button type="submit">Save</button>
    <a asp-action="Index">Back to List</a>
</form>
