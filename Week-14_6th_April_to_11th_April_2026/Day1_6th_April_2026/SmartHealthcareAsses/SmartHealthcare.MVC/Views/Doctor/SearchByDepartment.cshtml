@model SmartHealthcare.MVC.Models.DoctorSearchViewModel
@{
    ViewData["Title"] = "Find Doctors by Department";
}

<h4 class="fw-bold mb-4"><i class="bi bi-search me-2 text-primary"></i>Find Doctors by Department</h4>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="SearchByDepartment" method="get" class="row g-3">
            <div class="col-md-8">
                <label class="form-label fw-semibold">Select Department</label>
                <select name="departmentId" class="form-select form-select-lg" id="deptSelect">
                    <option value="">-- All Departments --</option>
                    @foreach (var dept in Model.Departments)
                    {
                        <option value="@dept.Id" selected="@(dept.Id == Model.SelectedDepartmentId)">
                            @dept.DepartmentName (@dept.DoctorCount doctors)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-search me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Doctors.Any())
{
    <div class="row g-3">
        @foreach (var doc in Model.Doctors)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                                 style="width:50px;height:50px;">
                                <i class="bi bi-person-badge text-primary fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0">Dr. @doc.FullName</h6>
                                <small class="text-muted">@doc.DepartmentName</small>
                            </div>
                        </div>
                        <p class="text-muted small mb-1">
                            <i class="bi bi-award me-1"></i>@(doc.Specialization ?? "General")
                        </p>
                        <p class="text-muted small mb-1">
                            <i class="bi bi-briefcase me-1"></i>@doc.ExperienceYears year(s) experience
                        </p>
                        <p class="text-muted small mb-1">
                            <i class="bi bi-clock me-1"></i>@(doc.Availability ?? "Contact for schedule")
                        </p>
                        <p class="fw-semibold text-primary mb-3">
                            <i class="bi bi-currency-rupee"></i>@doc.ConsultationFee.ToString("0") consultation fee
                        </p>
                        <div class="d-flex gap-2">
                            <a asp-controller="Doctor" asp-action="Details" asp-route-id="@doc.Id"
                               class="btn btn-outline-primary btn-sm flex-grow-1">View Profile</a>
                            <a asp-controller="Appointment" asp-action="Book"
                               asp-route-doctorId="@doc.Id"
                               class="btn btn-primary btn-sm flex-grow-1">Book</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (Model.SelectedDepartmentId.HasValue)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-person-x display-4 d-block mb-3"></i>
        <p>No doctors found in this department.</p>
    </div>
}
