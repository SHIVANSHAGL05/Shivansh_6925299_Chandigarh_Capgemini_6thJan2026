<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #f0f4f8; }
        .navbar-brand { font-weight: 700; letter-spacing: 0.5px; }
        .admin-badge { font-size: 11px; background: #ffc107; color: #000;
                       padding: 2px 8px; border-radius: 12px; vertical-align: middle; }
    </style>
</head>
<body>

    @* Task 6: Layout with navigation links *@
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">🎫 EventApp</a>

            <div class="navbar-nav ms-auto gap-1">
                <a class="nav-link" asp-page="/Index">Home</a>
                <a class="nav-link" asp-page="/Events/Register">Register Event</a>
                <a class="nav-link" asp-page="/Events/Index">View Participants</a>

                @* Task 7: Show admin badge when logged in as Admin *@
                @if (User.IsInRole("Admin"))
                {
                    <span class="nav-link">
                        <span class="admin-badge">ADMIN</span>
                    </span>
                    <a class="nav-link text-warning" asp-page="/Index" asp-route-logout="true">Logout</a>
                }
                else
                {
                    <a class="nav-link text-info" asp-page="/Index" asp-route-loginAsAdmin="true">Admin Login</a>
                }
            </div>
        </div>
    </nav>

    <main class="container my-4">
        @RenderBody()
    </main>

    <footer class="text-center text-muted py-3 border-top bg-white mt-5">
        <small>&copy; @DateTime.Now.Year EventApp — Razor Pages Case Study</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
