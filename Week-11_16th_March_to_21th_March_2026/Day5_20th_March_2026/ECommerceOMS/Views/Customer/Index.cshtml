@model IEnumerable<ECommerceOMS.Models.Customer>
@{
    ViewData["Title"] = "Customers";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-people me-2"></i>Customers</h1>
            <p class="mb-0 opacity-75">Manage registered customers</p>
        </div>
        <a asp-action="Create" class="btn btn-warning fw-semibold">
            <i class="bi bi-person-plus me-1"></i>Add Customer
        </a>
    </div>
</div>

<!-- Search -->
<div class="card mb-3 p-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-4">
            <input type="text" name="search" class="form-control" placeholder="Search by name or email…" value="@ViewBag.Search" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-1">Clear</a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>City</th>
                        <th>Registered</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="text-muted small">@c.Id</td>
                            <td class="fw-semibold">@c.FullName</td>
                            <td class="small">@c.Email</td>
                            <td class="small">@c.Phone</td>
                            <td class="small">@c.City</td>
                            <td class="small text-muted">@c.RegisteredOn.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (c.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people display-3 opacity-25"></i>
                <p class="mt-2">No customers found.</p>
            </div>
        }
    </div>
</div>
