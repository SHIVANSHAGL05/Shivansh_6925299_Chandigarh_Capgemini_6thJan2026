@model EmployeePortal.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header bg-dark text-white text-center py-3">
                <i class="bi bi-person-plus-fill fs-3 d-block mb-1"></i>
                <h5 class="mb-0">Create Account</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-key"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="Min 6 chars, 1 uppercase, 1 symbol" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <p class="text-muted small">
                        <i class="bi bi-info-circle me-1"></i>
                        New accounts are assigned the <strong>Employee</strong> role by default.
                    </p>

                    <button type="submit" class="btn btn-dark w-100">
                        <i class="bi bi-person-check me-1"></i>Register
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a href="/Account/Login">Already have an account? Login</a>
                </div>
            </div>
        </div>
    </div>
</div>
