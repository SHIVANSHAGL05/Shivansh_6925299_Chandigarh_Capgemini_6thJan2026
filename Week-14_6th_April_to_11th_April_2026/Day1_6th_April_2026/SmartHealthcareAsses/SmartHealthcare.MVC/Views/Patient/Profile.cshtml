@model PatientDto
@{
    ViewData["Title"] = "My Profile";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-person-circle text-primary me-2"></i>My Profile</h2>
    <a asp-action="EditProfile" asp-route-patientId="@Model.Id" class="btn btn-outline-primary">
        <i class="bi bi-pencil me-2"></i>Edit Profile
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body text-center p-4">
                <div class="avatar-circle-lg bg-primary text-white mx-auto mb-3">@Model.FullName[0]</div>
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <p class="text-muted mb-1 small">@Model.Email</p>
                <p class="text-muted small">@(Model.PhoneNumber ?? "No phone")</p>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold text-muted text-uppercase small mb-3">Vitals</h6>
                <div class="d-flex justify-content-between border-bottom py-2">
                    <span class="text-muted small"><i class="bi bi-droplet me-1 text-danger"></i>Blood Group</span>
                    <strong class="text-danger">@(Model.BloodGroup ?? "Not set")</strong>
                </div>
                <div class="d-flex justify-content-between border-bottom py-2">
                    <span class="text-muted small"><i class="bi bi-speedometer me-1"></i>Weight</span>
                    <strong>@(Model.Weight.HasValue ? $"{Model.Weight:0.0} kg" : "—")</strong>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted small"><i class="bi bi-arrows-vertical me-1"></i>Height</span>
                    <strong>@(Model.Height.HasValue ? $"{Model.Height:0} cm" : "—")</strong>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        @if (!string.IsNullOrEmpty(Model.AllergiesNotes))
        {
            <div class="card border-0 shadow-sm mb-4 border-start border-danger border-4">
                <div class="card-body">
                    <h6 class="text-danger fw-semibold mb-2"><i class="bi bi-exclamation-triangle me-2"></i>Allergies</h6>
                    <p class="mb-0">@Model.AllergiesNotes</p>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.MedicalHistory))
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-medical text-primary me-2"></i>Medical History</h6>
                </div>
                <div class="card-body"><p class="mb-0">@Model.MedicalHistory</p></div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.EmergencyContactName))
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-telephone text-warning me-2"></i>Emergency Contact</h6>
                </div>
                <div class="card-body">
                    <div class="fw-semibold">@Model.EmergencyContactName</div>
                    <div class="text-muted">@(Model.EmergencyContactPhone ?? "—")</div>
                </div>
            </div>
        }
        <div class="mt-3">
            <a asp-action="MyPrescriptions" class="btn btn-outline-info">
                <i class="bi bi-file-medical me-2"></i>View My Prescriptions
            </a>
        </div>
    </div>
</div>
