@model ShopCart.Models.Order
@{
    ViewData["Title"] = "Delivery Address";
    decimal total     = ViewBag.Total;
}

<h2 class="mb-4"><i class="bi bi-geo-alt me-2"></i>Checkout</h2>

<!-- Bootstrap Progress Bar — Step 2 active -->
<div class="mb-4">
    <div class="d-flex justify-content-between small text-muted mb-1">
        <span><a href="/Cart" class="text-muted">1. Cart</a></span>
        <span class="fw-bold text-dark">2. Address</span>
        <span>3. Payment</span>
        <span>4. Done</span>
    </div>
    <div class="progress" style="height: 8px;">
        <div class="progress-bar bg-dark" style="width: 50%;"></div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm p-4">
            <h5 class="mb-3">Delivery Address</h5>

            <form method="post" action="/Checkout/Address" novalidate>
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">Full Name *</label>
                    <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email *</label>
                        <input asp-for="Email" class="form-control" placeholder="you@email.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone *</label>
                        <input asp-for="Phone" class="form-control" placeholder="10-digit number" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Street Address *</label>
                    <textarea asp-for="Address" class="form-control" rows="2"
                              placeholder="House no., street, area"></textarea>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-7">
                        <label class="form-label fw-semibold">City *</label>
                        <input asp-for="City" class="form-control" placeholder="City" />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">PIN Code *</label>
                        <input asp-for="PinCode" class="form-control" placeholder="6-digit PIN" maxlength="6" />
                        <span asp-validation-for="PinCode" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <a href="/Cart" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back
                    </a>
                    <button type="submit" class="btn btn-dark flex-grow-1">
                        Continue to Payment <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Mini order summary -->
    <div class="col-lg-5">
        <div class="card shadow-sm p-4 bg-light">
            <h6 class="mb-3 text-muted">ORDER TOTAL</h6>
            <div class="fs-3 fw-bold text-success">₹@total.ToString("N0")</div>
            <small class="text-muted">Free shipping included</small>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Simple Bootstrap client-side validation highlight
document.querySelector('form').addEventListener('submit', function () {
    this.querySelectorAll('[required]').forEach(function (el) {
        el.classList.toggle('is-invalid', !el.value.trim());
    });
});
</script>
}
