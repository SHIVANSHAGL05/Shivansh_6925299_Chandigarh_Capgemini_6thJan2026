@model IEnumerable<LibraryManagement.Models.Book>
@{ ViewData["Title"] = "Books"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Library Books</h4>
        <small class="text-muted">
            @if (!string.IsNullOrEmpty(ViewBag.Search))
            {
                <span>Search results for: <strong>"@ViewBag.Search"</strong></span>
            }
            else if (!string.IsNullOrEmpty(ViewBag.Genre))
            {
                <span>Genre: <strong>@ViewBag.Genre</strong></span>
            }
            else
            {
                <span>All books in the library</span>
            }
        </small>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Add Book
    </a>
</div>

<!-- Search Bar -->
<div class="card mb-4">
    <div class="card-body py-2">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control form-control-sm"
                   placeholder="Search by title or author..." />
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-search"></i>
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
        </form>
    </div>
</div>

<!-- Books Table -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Genre</th>
                    <th>Price</th>
                    <th>Availability</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var book in Model)
                {
                    <tr>
                        <td class="text-muted">@i++</td>
                        <td class="fw-semibold">@book.Title</td>
                        <td>@book.Author</td>
                        <td>
                            <span class="badge bg-light text-dark border">@book.Genre</span>
                        </td>
                        <td class="text-success fw-semibold">@book.Price.ToString("C")</td>
                        <td>
                            @if (book.IsAvailable)
                            {
                                <span class="badge-available">
                                    <i class="bi bi-check-circle me-1"></i>Available
                                </span>
                            }
                            else
                            {
                                <span class="badge-unavailable">
                                    <i class="bi bi-x-circle me-1"></i>Checked Out
                                </span>
                            }
                        </td>
                        <td>
                            <!-- /Books/Details/1 — uses conventional route {id} -->
                            <a asp-action="Details" asp-route-id="@book.BookId"
                               class="btn btn-sm btn-outline-info me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@book.BookId"
                               class="btn btn-sm btn-outline-warning me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@book.BookId"
                               class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>No books found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white">
        <small class="text-muted">
            Total: <strong>@Model.Count()</strong> book(s) |
            Available: <strong>@Model.Count(b => b.IsAvailable)</strong>
        </small>
    </div>
</div>
