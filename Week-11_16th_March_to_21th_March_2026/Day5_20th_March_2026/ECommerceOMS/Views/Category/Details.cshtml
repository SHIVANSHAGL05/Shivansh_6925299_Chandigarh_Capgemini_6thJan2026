@model ECommerceOMS.Models.Category
@{
    ViewData["Title"] = Model.Name;
}
<div class="page-header"><h1><i class="bi bi-tags me-2"></i>@Model.Name</h1></div>
<div class="row g-4">
    <div class="col-md-4">
        <div class="card p-4">
            <h5 class="fw-bold">@Model.Name</h5>
            <p class="text-muted">@Model.Description</p>
            <hr>
            <p class="small"><strong>Display Order:</strong> @Model.DisplayOrder</p>
            <p class="small"><strong>Status:</strong>
                @if (Model.IsActive) { <span class="badge bg-success">Active</span> }
                else { <span class="badge bg-secondary">Inactive</span> }
            </p>
            <p class="small text-muted">Created: @Model.CreatedOn.ToString("dd MMM yyyy")</p>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm mt-2">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
            }
        </div>
    </div>
    <div class="col-md-8">
        <h5 class="fw-bold mb-3">Products in this Category (@Model.Products.Count)</h5>
        <div class="row g-2">
            @foreach (var p in Model.Products.Where(p => p.IsActive))
            {
                <div class="col-md-6">
                    <div class="card p-3">
                        <div class="fw-semibold">@p.Name</div>
                        <div class="d-flex justify-content-between mt-1">
                            <span class="text-primary fw-bold">₹@p.Price.ToString("N2")</span>
                            <span class="text-muted small">@p.StockQuantity in stock</span>
                        </div>
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id" class="stretched-link"></a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
