@model AppointmentDto
@{
    ViewData["Title"] = "Appointment Details";
    var role = Context.Session.GetString("UserRole");
    var badgeCls = Model.Status switch {
        AppointmentStatus.Pending    => "bg-warning text-dark",
        AppointmentStatus.Confirmed  => "bg-info text-white",
        AppointmentStatus.InProgress => "bg-primary",
        AppointmentStatus.Completed  => "bg-success",
        AppointmentStatus.Cancelled  => "bg-danger",
        _                            => "bg-secondary"
    };
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-check me-2"></i>Appointment #@Model.Id</h5>
                <span class="badge fs-6 @badgeCls">@Model.StatusName</span>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase small fw-semibold mb-1">Patient</h6>
                        <p class="fw-bold fs-5 mb-0">@Model.PatientName</p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase small fw-semibold mb-1">Doctor</h6>
                        <p class="fw-bold fs-5 mb-0">Dr. @Model.DoctorName</p>
                        <small class="text-muted">@Model.DoctorSpecializations</small>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted text-uppercase small fw-semibold mb-1"><i class="bi bi-calendar3 me-1"></i>Date</h6>
                        <p class="fw-semibold mb-0">@Model.AppointmentDate.ToString("dddd, dd MMM yyyy")</p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted text-uppercase small fw-semibold mb-1"><i class="bi bi-clock me-1"></i>Time</h6>
                        <p class="fw-semibold mb-0">@Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")</p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted text-uppercase small fw-semibold mb-1"><i class="bi bi-geo-alt me-1"></i>Type</h6>
                        <p class="fw-semibold mb-0">@Model.Type</p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase small fw-semibold mb-1"><i class="bi bi-currency-rupee me-1"></i>Fee</h6>
                        <p class="fw-semibold mb-0">
                            ₹@Model.Fee?.ToString("0")
                            @if (Model.IsPaid) { <span class="badge bg-success ms-1">Paid</span> }
                        </p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ReasonForVisit))
                    {
                        <div class="col-12">
                            <h6 class="text-muted text-uppercase small fw-semibold mb-1"><i class="bi bi-chat-text me-1"></i>Reason for Visit</h6>
                            <div class="bg-light rounded p-3">@Model.ReasonForVisit</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.DoctorNotes))
                    {
                        <div class="col-12">
                            <h6 class="text-muted text-uppercase small fw-semibold mb-1"><i class="bi bi-journal-medical me-1"></i>Doctor Notes</h6>
                            <div class="bg-light rounded p-3">@Model.DoctorNotes</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (role == "Doctor" && Model.Status != AppointmentStatus.Cancelled && Model.Status != AppointmentStatus.Completed)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom fw-semibold">
                    <i class="bi bi-pencil-square text-success me-2"></i>Update Status
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">New Status</label>
                                <select name="status" class="form-select">
                                    @foreach (var s in Enum.GetValues<AppointmentStatus>())
                                    {
                                        if (s == AppointmentStatus.Cancelled) continue;
                                        <option value="@((int)s)" selected="@(s == Model.Status)">@s</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-semibold">Clinical Notes</label>
                                <input type="text" name="notes" class="form-control" value="@Model.DoctorNotes" placeholder="Add notes..." />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-2"></i>Update</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }

        @if (role == "Patient" && Model.Status == AppointmentStatus.Pending)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <strong class="text-danger">Cancel Appointment</strong>
                        <p class="mb-0 small text-muted">This cannot be undone.</p>
                    </div>
                    <form asp-action="Cancel" method="post" onsubmit="return confirm('Cancel this appointment?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger"><i class="bi bi-x-circle me-2"></i>Cancel</button>
                    </form>
                </div>
            </div>
        }

        @if (role == "Doctor" && Model.Status == AppointmentStatus.Completed && !Model.IsPaid)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <strong class="text-warning"><i class="bi bi-receipt me-2"></i>Bill Not Created</strong>
                        <p class="mb-0 small text-muted">Generate a bill for this completed appointment.</p>
                    </div>
                    <a asp-controller="Doctor" asp-action="CreateBill" asp-route-appointmentId="@Model.Id" class="btn btn-pay btn-sm">
                        <i class="bi bi-receipt-cutoff me-1"></i>Create Bill
                    </a>
                </div>
            </div>
        }

        @if (Model.HasPrescription)
        {
            <div class="alert alert-info d-flex align-items-center mb-4">
                <i class="bi bi-file-medical fs-4 me-3"></i>
                <div><strong>Prescription Issued</strong> for this appointment.</div>
            </div>
        }

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>
