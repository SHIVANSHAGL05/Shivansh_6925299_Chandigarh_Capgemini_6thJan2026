@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle display-1 text-warning mb-3 d-block"></i>
    <h1 class="fw-bold">Something went wrong</h1>
    <p class="text-muted fs-5 mb-4">An unexpected error occurred. Please try again later.</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg me-2">
        <i class="bi bi-house me-2"></i>Go Home
    </a>
    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg">
        <i class="bi bi-arrow-left me-2"></i>Go Back
    </a>
</div>
