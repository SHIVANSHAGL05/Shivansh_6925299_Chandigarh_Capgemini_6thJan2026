@model LibraryManagement.Models.Book
@{ ViewData["Title"] = "Add Book"; }

<div class="mb-4">
    <h4 class="fw-bold mb-0">Add New Book</h4>
    <small class="text-muted">Fill in the book details below</small>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-plus-circle me-2"></i>Book Details</div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Clean Code" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Author" class="form-label">Author</label>
                        <input asp-for="Author" class="form-control" placeholder="e.g. Robert C. Martin" />
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ISBN" class="form-label">ISBN</label>
                        <input asp-for="ISBN" class="form-control" placeholder="978-XXXXXXXXXX" />
                        <span asp-validation-for="ISBN" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Genre" class="form-label">Genre</label>
                        <select asp-for="Genre" class="form-select">
                            <option value="">-- Select Genre --</option>
                            <option>Programming</option>
                            <option>Web Development</option>
                            <option>Software Architecture</option>
                            <option>Database</option>
                            <option>Cloud Computing</option>
                        </select>
                        <span asp-validation-for="Genre" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PublishedDate" class="form-label">Published Date</label>
                        <input asp-for="PublishedDate" class="form-control" type="date" />
                        <span asp-validation-for="PublishedDate" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label">Price ($)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsAvailable" class="form-check-label">Available for checkout</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Save Book
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
