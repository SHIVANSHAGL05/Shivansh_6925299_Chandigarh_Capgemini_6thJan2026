@model ECommerceOMS.Models.Category
@{
    ViewData["Title"] = "Delete Category";
}
<div class="row justify-content-center mt-4"><div class="col-md-6">
    <div class="card border-danger">
        <div class="card-header bg-danger text-white"><h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Delete Category</h5></div>
        <div class="card-body">
            <p>Delete <strong>@Model.Name</strong>?</p>
            @if (Model.Products.Any())
            {
                <div class="alert alert-danger small">
                    <i class="bi bi-x-circle me-1"></i>Cannot delete — this category has @Model.Products.Count product(s). Remove products first.
                </div>
            }
        </div>
        <div class="card-footer d-flex gap-2">
            @if (!Model.Products.Any())
            {
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                </form>
            }
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
</div></div>
