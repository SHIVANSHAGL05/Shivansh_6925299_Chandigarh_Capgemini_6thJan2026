@{
    ViewData["Title"] = "Home";
    var featured   = ViewBag.Featured   as IEnumerable<ProductCatalog.Models.Product>;
    var categories = ViewBag.Categories as IEnumerable<string>;
}

<!-- ── Hero ─────────────────────────────────────────────────────── -->
<section class="hero-section">
    <div class="hero-bg"></div>
    <div class="container hero-content">
        <div class="row align-items-center min-vh-hero">
            <div class="col-lg-6">
                <span class="hero-eyebrow">New arrivals just dropped</span>
                <h1 class="hero-title">Tech that <em>actually</em> matters.</h1>
                <p class="hero-subtitle">Curated peripherals, audio, and wearables for the modern workspace. No fluff, just great gear.</p>
                <div class="d-flex gap-3 flex-wrap mt-4">
                    <a href="/Products" class="btn btn-accent btn-lg px-4">
                        Shop All Products <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    <a href="/Products?sort=newest" class="btn btn-outline-light btn-lg px-4">
                        What's New
                    </a>
                </div>
                <div class="hero-stats mt-5">
                    <div class="hero-stat">
                        <span class="stat-num">@ViewBag.TotalCount+</span>
                        <span class="stat-label">Products</span>
                    </div>
                    <div class="hero-stat">
                        <span class="stat-num">4.6★</span>
                        <span class="stat-label">Avg. Rating</span>
                    </div>
                    <div class="hero-stat">
                        <span class="stat-num">Free</span>
                        <span class="stat-label">Shipping</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center">
                <div class="hero-image-cluster">
                    <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=600&q=80"
                         class="hero-img hero-img-main" alt="Headphones" />
                    <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=300&q=80"
                         class="hero-img hero-img-float" alt="Watch" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Category Pills ────────────────────────────────────────────── -->
<section class="py-5 bg-dark">
    <div class="container">
        <h2 class="section-heading text-white mb-4">Shop by Category</h2>
        <div class="d-flex flex-wrap gap-3">
            <a href="/Products" class="category-pill">
                <i class="bi bi-grid me-2"></i>All
            </a>
            @foreach (var cat in categories!)
            {
                var icon = cat switch {
                    "Audio"       => "bi-headphones",
                    "Wearables"   => "bi-watch",
                    "Peripherals" => "bi-keyboard",
                    "Accessories" => "bi-plug",
                    _             => "bi-tag"
                };
                <a href="/Products?category=@cat" class="category-pill">
                    <i class="bi @icon me-2"></i>@cat
                </a>
            }
        </div>
    </div>
</section>

<!-- ── Featured Products ─────────────────────────────────────────── -->
<section class="py-6 bg-darker">
    <div class="container">
        <div class="d-flex align-items-end justify-content-between mb-5">
            <div>
                <span class="section-eyebrow">Hand-picked</span>
                <h2 class="section-heading text-white">Featured Products</h2>
            </div>
            <a href="/Products" class="btn btn-outline-light btn-sm">
                View all <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="row g-4">
            @foreach (var product in featured!)
            {
                <div class="col-sm-6 col-xl-3">
                    <div class="product-card">
                        <div class="product-img-wrap">
                            <img src="@product.ImageUrl" alt="@product.Name" class="product-img" loading="lazy" />
                            @if (product.IsNew)
                            {
                                <span class="badge-new">NEW</span>
                            }
                            <div class="product-overlay">
                                <a href="/Products/Details/@product.Id" class="btn btn-light btn-sm">
                                    <i class="bi bi-eye me-1"></i>Quick View
                                </a>
                            </div>
                        </div>
                        <div class="product-body">
                            <span class="product-category">@product.Category</span>
                            <h5 class="product-name">
                                <a href="/Products/Details/@product.Id">@product.Name</a>
                            </h5>
                            <div class="product-meta">
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star@(i <= Math.Round(product.Rating) ? "-fill" : "")"></i>
                                    }
                                    <span class="review-count">(@product.ReviewCount)</span>
                                </div>
                                <span class="product-price">$@product.Price.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── Value Props ────────────────────────────────────────────────── -->
<section class="py-5 bg-dark border-top border-secondary border-opacity-25">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <i class="bi bi-truck value-icon"></i>
                <h6 class="text-white mt-2 mb-1">Free Shipping</h6>
                <small class="text-muted">On all orders over $50</small>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-arrow-repeat value-icon"></i>
                <h6 class="text-white mt-2 mb-1">Easy Returns</h6>
                <small class="text-muted">30-day hassle-free returns</small>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-shield-check value-icon"></i>
                <h6 class="text-white mt-2 mb-1">2-Year Warranty</h6>
                <small class="text-muted">On all products</small>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-headset value-icon"></i>
                <h6 class="text-white mt-2 mb-1">24/7 Support</h6>
                <small class="text-muted">Real humans, real help</small>
            </div>
        </div>
    </div>
</section>
