@model BookAppointmentViewModel
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-plus me-2"></i>Book an Appointment</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Book" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>

                    <div class="mb-4">
                        <label asp-for="DoctorProfileId" class="form-label fw-semibold">
                            <i class="bi bi-person-badge me-1 text-primary"></i>Select Doctor
                        </label>
                        <select asp-for="DoctorProfileId" class="form-select form-select-lg" id="doctorSelect">
                            <option value="">-- Choose a Doctor --</option>
                            @foreach (var d in Model.Doctors)
                            {
                                <option value="@d.Id"
                                        data-fee="@d.ConsultationFee"
                                        data-spec="@string.Join(", ", d.Specializations.Select(s => s.Name))"
                                        selected="@(d.Id == Model.DoctorProfileId)">
                                    Dr. @d.FullName — @string.Join(", ", d.Specializations.Select(s => s.Name))
                                    (₹@d.ConsultationFee.ToString("0"))
                                </option>
                            }
                        </select>
                        <span asp-validation-for="DoctorProfileId" class="text-danger small"></span>

                        <!-- Doctor info card (shown on select) -->
                        <div id="doctorInfo" class="alert alert-info mt-2 d-none">
                            <strong id="doctorSpec"></strong> · Consultation Fee:
                            <strong id="doctorFee"></strong>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="AppointmentDate" class="form-label fw-semibold">
                                <i class="bi bi-calendar3 me-1 text-primary"></i>Date
                            </label>
                            <input asp-for="AppointmentDate" type="date" class="form-control form-control-lg"
                                   min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="StartTimeStr" class="form-label fw-semibold">
                                <i class="bi bi-clock me-1 text-primary"></i>Time Slot
                            </label>
                            <select asp-for="StartTimeStr" class="form-select form-select-lg">
                                @foreach (var h in Enumerable.Range(9, 9))
                                {
                                    <option value="@($"{h:00}:00")">@($"{h:00}:00")</option>
                                    <option value="@($"{h:00}:30")">@($"{h:00}:30")</option>
                                }
                            </select>
                            <span asp-validation-for="StartTimeStr" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Type" class="form-label fw-semibold">
                            <i class="bi bi-geo-alt me-1 text-primary"></i>Appointment Type
                        </label>
                        <div class="d-flex gap-3">
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="Type" value="0" id="inPerson" checked />
                                <label class="form-check-label" for="inPerson">
                                    <i class="bi bi-building me-1"></i>In-Person
                                </label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="Type" value="1" id="online" />
                                <label class="form-check-label" for="online">
                                    <i class="bi bi-camera-video me-1"></i>Online
                                </label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="Type" value="2" id="phone" />
                                <label class="form-check-label" for="phone">
                                    <i class="bi bi-telephone me-1"></i>Phone
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ReasonForVisit" class="form-label fw-semibold">
                            <i class="bi bi-chat-text me-1 text-primary"></i>Reason for Visit
                            <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <textarea asp-for="ReasonForVisit" class="form-control" rows="3"
                                  placeholder="Briefly describe your symptoms or reason for visit..."></textarea>
                        <span asp-validation-for="ReasonForVisit" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary btn-lg px-5 fw-semibold">
                            <i class="bi bi-calendar-check me-2"></i>Confirm Booking
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('doctorSelect').addEventListener('change', function () {
            const opt = this.options[this.selectedIndex];
            const info = document.getElementById('doctorInfo');
            if (opt.value) {
                document.getElementById('doctorSpec').textContent = opt.dataset.spec;
                document.getElementById('doctorFee').textContent  = '₹' + opt.dataset.fee;
                info.classList.remove('d-none');
            } else {
                info.classList.add('d-none');
            }
        });
        // Trigger on load if pre-selected
        document.getElementById('doctorSelect').dispatchEvent(new Event('change'));
    </script>
}
