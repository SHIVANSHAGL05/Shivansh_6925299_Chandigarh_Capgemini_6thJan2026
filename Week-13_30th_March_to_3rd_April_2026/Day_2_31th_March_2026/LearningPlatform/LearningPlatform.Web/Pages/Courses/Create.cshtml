@page
@model LearningPlatform.Web.Pages.Courses.CreateModel
@{
    ViewData["Title"] = "Create Course";
}

<div class="form-page">
    <div class="form-card">
        <h2>Create New Course</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Input.Title">Course Title *</label>
                <input asp-for="Input.Title" placeholder="e.g. Complete ASP.NET Core Bootcamp" required />
            </div>

            <div class="form-group">
                <label asp-for="Input.Description">Description *</label>
                <textarea asp-for="Input.Description" rows="4" placeholder="Describe what students will learn..."></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.Category">Category *</label>
                    <select asp-for="Input.Category">
                        <option value="Programming">Programming</option>
                        <option value="Design">Design</option>
                        <option value="Business">Business</option>
                        <option value="Data Science">Data Science</option>
                        <option value="DevOps">DevOps</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="Input.Level">Level</label>
                    <select asp-for="Input.Level">
                        <option value="Beginner">Beginner</option>
                        <option value="Intermediate">Intermediate</option>
                        <option value="Advanced">Advanced</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Input.Price">Price (₹) — enter 0 for free</label>
                <input asp-for="Input.Price" type="number" min="0" max="99999" step="0.01" />
            </div>

            <button type="submit" class="btn-primary btn-full">Publish Course</button>
        </form>
    </div>
</div>
