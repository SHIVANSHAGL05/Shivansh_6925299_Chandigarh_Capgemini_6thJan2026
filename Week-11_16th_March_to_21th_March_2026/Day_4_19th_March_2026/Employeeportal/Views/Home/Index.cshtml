@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <div class="mb-4">
        <i class="fas fa-building fa-5x text-primary"></i>
    </div>
    <h1 class="display-4 fw-bold text-primary">Employee Management Portal</h1>
    <p class="lead text-muted mt-3">
        A secure platform for managing your organization's employees with role-based access control.
    </p>

    @if (!User.Identity!.IsAuthenticated)
    {
        <div class="mt-4">
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg me-3">
                <i class="fas fa-sign-in-alt me-2"></i>Login
            </a>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-primary btn-lg">
                <i class="fas fa-user-plus me-2"></i>Register
            </a>
        </div>
    }
    else
    {
        <div class="mt-4">
            <a asp-controller="Employee" asp-action="Index" class="btn btn-primary btn-lg me-3">
                <i class="fas fa-users me-2"></i>View Employees
            </a>
            <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-primary btn-lg">
                <i class="fas fa-chart-bar me-2"></i>Dashboard
            </a>
        </div>
    }
</div>

<div class="row g-4 mt-4">
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <i class="fas fa-shield-alt fa-3x text-primary mb-3"></i>
            <h5>Secure Authentication</h5>
            <p class="text-muted">ASP.NET Identity with role-based access control for Admin and Employee roles.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <i class="fas fa-users-cog fa-3x text-primary mb-3"></i>
            <h5>Employee Management</h5>
            <p class="text-muted">Full CRUD operations for managing employee records with search and pagination.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <i class="fas fa-chart-line fa-3x text-primary mb-3"></i>
            <h5>Dashboard & Reports</h5>
            <p class="text-muted">Overview of total employees and departments at a glance.</p>
        </div>
    </div>
</div>
