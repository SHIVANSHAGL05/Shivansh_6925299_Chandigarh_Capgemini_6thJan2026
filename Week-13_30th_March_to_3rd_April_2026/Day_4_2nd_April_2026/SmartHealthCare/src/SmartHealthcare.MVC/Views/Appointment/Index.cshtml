@model IEnumerable<SmartHealthcare.Models.DTOs.AppointmentDTO>
@{
    ViewData["Title"] = "My Appointments";
    var role = ViewBag.Role as string;
}

<div class="container-fluid mt-4">
    <div class="page-hero" data-reveal>
        <div>
            <h1 class="mb-1"><i class="bi bi-calendar-check"></i> Appointments</h1>
            <p class="text-muted mb-0">Track all booked appointments and view detailed consultation information.</p>
        </div>
        <div>
            @if (role == "Patient")
            {
                <a asp-action="Create" class="btn btn-success btn-lg"><i class="bi bi-plus-circle"></i> Book New Appointment</a>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4 mb-4" data-reveal>
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 appointment-card">
                        <div class="card-header bg-white border-0 pt-3 px-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="mb-0"><i class="bi bi-calendar-event"></i> Appointment #@item.Id</h6>
                                <span class="status-pill @GetStatusClass(item.Status)">@item.Status</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="info-panel">
                                <p class="mb-3">
                                    <strong><i class="bi bi-person"></i> Patient:</strong><br />
                                    <span class="ms-3">@item.PatientName</span>
                                </p>
                                <p class="mb-3">
                                    <strong><i class="bi bi-hospital"></i> Doctor:</strong><br />
                                    <span class="ms-3">Dr. @item.DoctorName</span>
                                </p>
                                <p class="mb-3">
                                    <strong><i class="bi bi-clock"></i> Date & Time:</strong><br />
                                    <span class="ms-3">@item.AppointmentDate.ToString("dd-MMM-yyyy HH:mm")</span>
                                </p>
                                @if (!string.IsNullOrEmpty(item.Notes))
                                {
                                    <p class="mb-3">
                                        <strong><i class="bi bi-sticky"></i> Notes:</strong><br />
                                        <span class="ms-3 text-muted">@item.Notes</span>
                                    </p>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                            <div class="d-grid gap-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary w-100">
                                    <i class="bi bi-info-circle"></i> View Details
                                </a>
                                @if (role == "Doctor" && item.Status == "Booked")
                                {
                                    <form asp-action="MarkCompleted" method="post">
                                        <input type="hidden" name="appointmentId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-success w-100">
                                            <i class="bi bi-check2-circle"></i> Mark Completed
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="section-shell text-center py-5" data-reveal>
            <h4 class="alert-heading"><i class="bi bi-info-circle"></i> No Appointments</h4>
            <p class="text-muted">You haven't booked any appointments yet.</p>
            @if (role == "Patient")
            {
                <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Book Your First Appointment</a>
            }
        </div>
    }
</div>

@functions {
    private string GetStatusClass(string status)
    {
        return status?.ToLower() switch
        {
            "booked" => "status-pending",
            "completed" => "status-completed",
            "cancelled" => "status-cancelled",
            _ => "status-default"
        };
    }
}
