@* Task 4: Create form with validation — model is Book *@
@model LibraryApp.Models.Book
@{
    ViewData["Title"] = "Add New Book";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Add New Book</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. The Pragmatic Programmer" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label fw-semibold"></label>
                        <input asp-for="Author" class="form-control" placeholder="e.g. Andrew Hunt" />
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PublishedYear" class="form-label fw-semibold"></label>
                        <input asp-for="PublishedYear" class="form-control" type="number"
                               min="1000" max="2100" placeholder="e.g. 1999" />
                        <span asp-validation-for="PublishedYear" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Genre" class="form-label fw-semibold"></label>
                        <select asp-for="Genre" class="form-select">
                            <option value="">-- Select Genre --</option>
                            <option>Fiction</option>
                            <option>Non-Fiction</option>
                            <option>Science</option>
                            <option>Technology</option>
                            <option>History</option>
                            <option>Biography</option>
                            <option>Fantasy</option>
                            <option>Mystery</option>
                        </select>
                        <span asp-validation-for="Genre" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">💾 Save Book</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        @* Validation summary (shows all errors at once) *@
        <div asp-validation-summary="ModelOnly" class="text-danger mt-2 small"></div>
    </div>
</div>

@section Scripts {
    @* Task 4: Client-side validation *@
    <partial name="_ValidationScriptsPartial" />
}
