@model DoctorDto
@{
    ViewData["Title"] = $"Dr. {Model.FullName}";
    var initials = string.Join("", Model.FullName.Split(' ').Take(2).Select(w => w[0]));
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="d-flex gap-4 align-items-center flex-wrap">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width:90px;height:90px;font-size:2.2rem;font-weight:700">
                        @initials
                    </div>
                    <div class="flex-grow-1">
                        <h3 class="fw-bold mb-1">Dr. @Model.FullName</h3>
                        <p class="text-muted mb-2">@string.Join(" | ", Model.Specializations.Select(s => s.Name))</p>
                        <div class="d-flex flex-wrap gap-3 text-muted small">
                            <span><i class="bi bi-briefcase me-1"></i>@Model.ExperienceYears years experience</span>
                            <span><i class="bi bi-award me-1"></i>@Model.LicenseNumber</span>
                            @if (!string.IsNullOrEmpty(Model.Email))
                            {
                                <span><i class="bi bi-envelope me-1"></i>@Model.Email</span>
                            }
                            @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                            {
                                <span><i class="bi bi-telephone me-1"></i>@Model.PhoneNumber</span>
                            }
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="fs-4 fw-bold text-primary">₹@Model.ConsultationFee.ToString("0")</div>
                        <div class="small text-muted">Consultation Fee</div>
                        @if (Model.IsAvailable)
                        {
                            <span class="badge bg-success mt-2">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger mt-2">Unavailable</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-8">
                @if (!string.IsNullOrEmpty(Model.Biography))
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white fw-semibold border-bottom">
                            <i class="bi bi-person-lines-fill text-primary me-2"></i>About
                        </div>
                        <div class="card-body">@Model.Biography</div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Qualifications))
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white fw-semibold border-bottom">
                            <i class="bi bi-mortarboard text-primary me-2"></i>Qualifications
                        </div>
                        <div class="card-body">@Model.Qualifications</div>
                    </div>
                }
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="bi bi-tags text-success me-2"></i>Specializations
                    </div>
                    <div class="card-body">
                        @foreach (var s in Model.Specializations)
                        {
                            <div class="d-flex align-items-center mb-2">
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle me-2">@s.Name</span>
                                @if (s.IsPrimary)
                                {
                                    <span class="badge bg-warning text-dark">Primary</span>
                                }
                            </div>
                        }
                    </div>
                </div>

                @if (Context.Session.GetString("UserRole") == "Patient" && Model.IsAvailable)
                {
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center py-4">
                            <i class="bi bi-calendar-plus display-5 text-primary d-block mb-3"></i>
                            <p class="text-muted small mb-3">Book a consultation with Dr. @Model.FullName</p>
                            <a asp-controller="Appointment" asp-action="Book" asp-route-doctorId="@Model.Id"
                               class="btn btn-primary w-100">
                                <i class="bi bi-calendar-plus me-2"></i>Book Appointment
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Doctors
        </a>
    </div>
</div>
