@model UniversityManagement.Models.Department
@{ ViewData["Title"] = "Edit Department"; }

<div class="mb-4">
    <h4 class="fw-bold mb-0">Edit Department</h4>
    <small class="text-muted">Update department information</small>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil-square me-2"></i>Edit Department
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                    <input type="hidden" asp-for="DepartmentId" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Department Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Budget" class="form-label">Annual Budget ($)</label>
                        <input asp-for="Budget" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="Budget" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning text-white">
                            <i class="bi bi-check-lg me-1"></i> Update Department
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
