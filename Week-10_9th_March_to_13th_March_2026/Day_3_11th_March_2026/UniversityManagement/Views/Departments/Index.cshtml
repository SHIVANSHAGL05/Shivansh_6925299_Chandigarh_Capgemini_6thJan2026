@model IEnumerable<UniversityManagement.Models.Department>
@{ ViewData["Title"] = "Departments"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Departments</h4>
        <small class="text-muted">University academic departments</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Department
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Department Name</th>
                    <th>Annual Budget</th>
                    <th>No. of Instructors</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var dept in Model)
                {
                    <tr>
                        <td class="text-muted">@i++</td>
                        <td class="fw-semibold">@dept.Name</td>
                        <td class="text-success fw-semibold">@dept.Budget.ToString("C")</td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                <i class="bi bi-people me-1"></i>@dept.Instructors.Count()
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@dept.DepartmentId"
                               class="btn btn-sm btn-outline-info me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@dept.DepartmentId"
                               class="btn btn-sm btn-outline-warning me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@dept.DepartmentId"
                               class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i> No departments found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
