<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | NEXUS Store</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts: Syne (display) + DM Sans (body) -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet" />
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ── Navbar ───────────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
    <div class="container">
        <a class="navbar-brand" href="/">
            <span class="brand-logo">NX</span>
            <span class="brand-text">NEXUS</span>
        </a>

        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home" ? "active" : "")"
                       href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Products" ? "active" : "")"
                       href="/Products">Products</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Contact" ? "active" : "")"
                       href="/Contact">Contact</a>
                </li>
            </ul>

            <!-- Inline search in navbar -->
            <form class="d-flex nav-search" action="/Products" method="get">
                <div class="input-group">
                    <input class="form-control form-control-sm nav-search-input"
                           type="search" name="q" placeholder="Search products…"
                           value="@(Context.Request.Query["q"].ToString())" />
                    <button class="btn btn-sm btn-accent" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</nav>

<!-- ── Page content ─────────────────────────────────────────────── -->
<main>
    @RenderBody()
</main>

<!-- ── Footer ───────────────────────────────────────────────────── -->
<footer class="site-footer">
    <div class="container">
        <div class="row g-4 py-5">
            <div class="col-lg-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="brand-logo brand-logo-sm">NX</span>
                    <span class="brand-text fs-5">NEXUS</span>
                </div>
                <p class="text-muted small">Curated tech for people who care about quality. Every product hand-picked by our team.</p>
            </div>
            <div class="col-6 col-lg-2">
                <h6 class="footer-heading">Shop</h6>
                <ul class="list-unstyled footer-links">
                    <li><a href="/Products">All Products</a></li>
                    <li><a href="/Products?category=Audio">Audio</a></li>
                    <li><a href="/Products?category=Wearables">Wearables</a></li>
                    <li><a href="/Products?category=Peripherals">Peripherals</a></li>
                </ul>
            </div>
            <div class="col-6 col-lg-2">
                <h6 class="footer-heading">Company</h6>
                <ul class="list-unstyled footer-links">
                    <li><a href="/">About</a></li>
                    <li><a href="/Contact">Contact</a></li>
                </ul>
            </div>
            <div class="col-lg-4">
                <h6 class="footer-heading">Stay in the loop</h6>
                <div class="input-group newsletter-input">
                    <input type="email" class="form-control form-control-sm" placeholder="your@email.com" />
                    <button class="btn btn-accent btn-sm">Subscribe</button>
                </div>
                <div class="social-icons mt-3">
                    <a href="#"><i class="bi bi-twitter-x"></i></a>
                    <a href="#"><i class="bi bi-instagram"></i></a>
                    <a href="#"><i class="bi bi-youtube"></i></a>
                    <a href="#"><i class="bi bi-linkedin"></i></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <small class="text-muted">&copy; @DateTime.Now.Year NEXUS Store. All rights reserved.</small>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
