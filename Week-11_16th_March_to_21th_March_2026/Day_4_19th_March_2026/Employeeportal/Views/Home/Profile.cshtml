@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@{
    ViewData["Title"] = "My Profile";
    var user = await UserManager.GetUserAsync(User);
    var roles = await UserManager.GetRolesAsync(user!);
}

<h2 class="mb-4"><i class="fas fa-id-card me-2 text-primary"></i>My Profile</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-user me-2"></i>User Information
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th><i class="fas fa-envelope me-2 text-primary"></i>Email</th>
                        <td>@user?.Email</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-user me-2 text-primary"></i>Username</th>
                        <td>@user?.UserName</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-shield-alt me-2 text-primary"></i>Role(s)</th>
                        <td>
                            @foreach (var role in roles)
                            {
                                <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") me-1">@role</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
