@{
    ViewData["Title"] = "Admin Dashboard";
    var recentBookings = ViewBag.RecentBookings as List<HotelSimple.Models.Booking>;
    var rooms          = ViewBag.Rooms          as List<HotelSimple.Models.Room>;
}

<h2 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h2>

<!-- Success Alert -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card stat-card blue p-3">
            <div class="d-flex align-items-center">
                <i class="bi bi-door-closed fs-2 text-primary me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">@ViewBag.TotalRooms</div>
                    <div class="text-muted small">Total Rooms</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card stat-card green p-3">
            <div class="d-flex align-items-center">
                <i class="bi bi-calendar-check fs-2 text-success me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">@ViewBag.TotalBookings</div>
                    <div class="text-muted small">Total Bookings</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card stat-card orange p-3">
            <div class="d-flex align-items-center">
                <i class="bi bi-person-check fs-2 text-warning me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">@ViewBag.ActiveBookings</div>
                    <div class="text-muted small">Active Bookings</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card stat-card red p-3">
            <div class="d-flex align-items-center">
                <i class="bi bi-currency-rupee fs-2 text-danger me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">₹@((ViewBag.TotalRevenue as decimal? ?? 0).ToString("N0"))</div>
                    <div class="text-muted small">Total Revenue</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chart + Room List -->
<div class="row g-4 mb-4">
    <!-- Bar Chart -->
    <div class="col-md-7">
        <div class="card p-3">
            <h5 class="mb-3">Revenue by Room Type</h5>
            <canvas id="revenueChart" height="220"></canvas>
        </div>
    </div>

    <!-- Rooms Summary -->
    <div class="col-md-5">
        <div class="card p-3 h-100">
            <h5 class="mb-3">Rooms Overview</h5>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Room</th>
                            <th>Type</th>
                            <th>Price/Night</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (rooms != null)
                        {
                            @foreach (var room in rooms)
                            {
                                <tr>
                                    <td>@room.RoomNumber</td>
                                    <td>
                                        <span class="badge @(room.RoomType == "Suite" ? "bg-warning text-dark" : room.RoomType == "Deluxe" ? "bg-purple" : "bg-primary")">
                                            @room.RoomType
                                        </span>
                                    </td>
                                    <td>₹@room.PricePerNight.ToString("N0")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Recent Bookings -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Recent Bookings</h5>
        <a href="/Admin/Bookings" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ref</th>
                    <th>Guest</th>
                    <th>Room</th>
                    <th>Check-In</th>
                    <th>Check-Out</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (recentBookings != null)
                {
                    @foreach (var b in recentBookings)
                    {
                        <tr>
                            <td><strong>@b.BookingRef</strong></td>
                            <td>@b.Customer.FullName</td>
                            <td>@b.Room.RoomNumber (@b.Room.RoomType)</td>
                            <td>@b.CheckIn.ToString("dd MMM")</td>
                            <td>@b.CheckOut.ToString("dd MMM")</td>
                            <td class="text-success fw-semibold">₹@b.TotalAmount.ToString("N0")</td>
                            <td>
                                @{
                                    var colour = b.Status == "Confirmed" ? "success" : b.Status == "Cancelled" ? "danger" : "secondary";
                                }
                                <span class="badge bg-@colour">@b.Status</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
// Simple bar chart using Chart.js
const ctx = document.getElementById('revenueChart').getContext('2d');
new Chart(ctx, {
    type: 'bar',
    data: {
        labels: ['Standard', 'Deluxe', 'Suite'],
        datasets: [{
            label: 'Revenue (₹)',
            data: [
                @((ViewBag.RecentBookings as List<HotelSimple.Models.Booking>)?.Where(b => b.Room.RoomType == "Standard" && b.Status != "Cancelled").Sum(b => b.TotalAmount) ?? 0),
                @((ViewBag.RecentBookings as List<HotelSimple.Models.Booking>)?.Where(b => b.Room.RoomType == "Deluxe"   && b.Status != "Cancelled").Sum(b => b.TotalAmount) ?? 0),
                @((ViewBag.RecentBookings as List<HotelSimple.Models.Booking>)?.Where(b => b.Room.RoomType == "Suite"    && b.Status != "Cancelled").Sum(b => b.TotalAmount) ?? 0)
            ],
            backgroundColor: ['#0d6efd', '#6f42c1', '#fd7e14'],
            borderRadius: 6
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales:  { y: { beginAtZero: true } }
    }
});
</script>
}
