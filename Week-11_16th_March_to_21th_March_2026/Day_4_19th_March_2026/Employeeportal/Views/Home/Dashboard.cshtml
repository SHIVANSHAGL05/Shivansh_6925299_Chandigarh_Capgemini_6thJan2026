@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4"><i class="fas fa-chart-bar me-2 text-primary"></i>Dashboard</h2>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card text-center p-4" style="border-left: 5px solid #1a237e;">
            <i class="fas fa-users fa-3x text-primary mb-3"></i>
            <h1 class="display-4 fw-bold text-primary">@ViewData["TotalEmployees"]</h1>
            <h5 class="text-muted">Total Employees</h5>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card text-center p-4" style="border-left: 5px solid #c62828;">
            <i class="fas fa-sitemap fa-3x text-danger mb-3"></i>
            <h1 class="display-4 fw-bold text-danger">@ViewData["TotalDepartments"]</h1>
            <h5 class="text-muted">Total Departments</h5>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Quick Actions</h5>
        <a asp-controller="Employee" asp-action="Index" class="btn btn-primary me-2">
            <i class="fas fa-list me-1"></i>View All Employees
        </a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Employee" asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus me-1"></i>Add Employee
            </a>
        }
    </div>
</div>
