@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header bg-dark text-white text-center py-3">
                <i class="bi bi-person-circle fs-1 d-block mb-1"></i>
                <h5 class="mb-0">My Profile</h5>
            </div>
            <div class="card-body p-4">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-semibold"><i class="bi bi-envelope me-2 text-muted"></i>Email</span>
                        <span>@ViewBag.Email</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-semibold"><i class="bi bi-shield me-2 text-muted"></i>Role</span>
                        @if (ViewBag.Role == "Admin")
                        {
                            <span class="badge bg-danger fs-6">@ViewBag.Role</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6">@ViewBag.Role</span>
                        }
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-semibold"><i class="bi bi-check-circle me-2 text-muted"></i>Status</span>
                        <span class="badge bg-success">Active</span>
                    </li>
                </ul>
                <div class="mt-4 text-center">
                    <a href="/" class="btn btn-outline-dark">
                        <i class="bi bi-house me-1"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
