@model List<DoctorDto>
@{
    ViewData["Title"] = "Manage Doctors";
    int currentPage      = ViewBag.CurrentPage  ?? 1;
    int totalPages       = ViewBag.TotalPages   ?? 1;
    int totalCount       = ViewBag.TotalCount   ?? 0;
    string? search       = ViewBag.Search;
    int? specId          = ViewBag.SpecializationId as int?;
    var specs            = ViewBag.Specializations as List<SpecializationDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-person-badge text-success me-2"></i>Doctors</h2>
        <small class="text-muted">@totalCount total registered doctors</small>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control"
                           placeholder="Search by name..." value="@search" />
                </div>
            </div>
            <div class="col-md-4">
                <select name="specializationId" class="form-select">
                    <option value="">All Specializations</option>
                    @foreach (var s in specs)
                    {
                        <option value="@s.Id" selected="@(specId == s.Id)">@s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
            <div class="col-md-1">
                <a asp-action="Doctors" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-person-x display-3 d-block mb-3 opacity-50"></i>
                <h5>No doctors found.</h5>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th><th>Name</th><th>Specializations</th>
                            <th>Experience</th><th>Fee</th><th>Status</th><th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model)
                        {
                            <tr>
                                <td class="text-muted small">#@d.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-circle bg-success text-white" style="width:32px;height:32px;font-size:.85rem">
                                            @d.FullName[0]
                                        </div>
                                        <div>
                                            <div class="fw-semibold">Dr. @d.FullName</div>
                                            <div class="small text-muted">@d.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @foreach (var s in d.Specializations.Take(2))
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary me-1">@s.Name</span>
                                    }
                                    @if (d.Specializations.Count > 2)
                                    {
                                        <span class="badge bg-secondary">+@(d.Specializations.Count - 2)</span>
                                    }
                                </td>
                                <td>@d.ExperienceYears yrs</td>
                                <td class="text-success fw-semibold">₹@d.ConsultationFee.ToString("0")</td>
                                <td>
                                    @if (d.IsAvailable)
                                    {
                                        <span class="badge bg-success">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Unavailable</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a asp-controller="Doctor" asp-action="Details" asp-route-id="@d.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="DeleteDoctor" asp-route-id="@d.Id" method="post"
                                              onsubmit="return confirm('Remove Dr. @d.FullName?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center p-3 border-top">
                    <small class="text-muted">Page @currentPage of @totalPages</small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Doctors"
                                       asp-route-page="@i" asp-route-search="@search"
                                       asp-route-specializationId="@specId">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>
