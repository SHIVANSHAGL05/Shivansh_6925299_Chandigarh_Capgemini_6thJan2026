@model IEnumerable<UniversityManagement.Models.Instructor>
@{ ViewData["Title"] = "Instructors"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Instructors</h4>
        <small class="text-muted">Faculty members across all departments</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Instructor
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Courses Teaching</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var instructor in Model)
                {
                    <tr>
                        <td class="text-muted">@i++</td>
                        <td class="fw-semibold">@instructor.Name</td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                <i class="bi bi-building me-1"></i>
                                @(instructor.Department?.Name ?? "Unassigned")
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                <i class="bi bi-book me-1"></i>
                                @instructor.Courses.Count() course(s)
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@instructor.InstructorId"
                               class="btn btn-sm btn-outline-info me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@instructor.InstructorId"
                               class="btn btn-sm btn-outline-warning me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@instructor.InstructorId"
                               class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i> No instructors found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
