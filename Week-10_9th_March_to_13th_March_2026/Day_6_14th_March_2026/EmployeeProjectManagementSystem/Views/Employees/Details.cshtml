@model EmployeeProjectManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<h2>Employee Details</h2>

<dl>
    <dt>Name</dt>
    <dd>@Model.Name</dd>
    <dt>Email</dt>
    <dd>@Model.Email</dd>
    <dt>Department</dt>
    <dd>@Model.Department?.Name</dd>
</dl>

<h4>Assigned Projects</h4>
<ul>
    @foreach (var ep in Model.EmployeeProjects)
    {
        <li>@ep.Project?.Title — Assigned: @ep.AssignedDate.ToShortDateString()</li>
    }
</ul>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
<a asp-action="Index">Back to List</a>
