@page
@model LearningPlatform.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-container">
    <div class="auth-card">
        <h2>Welcome Back</h2>
        <p class="auth-subtitle">Sign in to your account</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" type="email" placeholder="you@example.com" required />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" placeholder="Min 6 characters" required />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>
            <button type="submit" class="btn-primary btn-full">Sign In</button>
        </form>

        <p class="auth-link">Don't have an account? <a href="/Auth/Register">Register</a></p>

        <div class="demo-hint">
            <strong>Demo accounts:</strong><br/>
            Student: <code>student@learnhub.com</code> / <code>Student@123</code><br/>
            Instructor: <code>instructor@learnhub.com</code> / <code>Instructor@123</code>
        </div>
    </div>
</div>
