@{
    ViewData["Title"] = "Place New Order";
    int? preSelectedCustomerId = ViewBag.CustomerId;
}

<h1>Place New Order</h1>
<hr />

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (preSelectedCustomerId != null)
{
    <div class="alert alert-success">
        Customer created successfully! Now place their first order below.
    </div>
}

<div class="card" style="max-width:650px;">
    <div class="card-body">
        <form method="post" action="/Orders/Create">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-bold">Customer</label>
                <select name="CustomerId" class="form-select" required>
                    <option value="">-- Select Customer --</option>
                    @foreach (var customer in ViewBag.Customers)
                    {
                        if (preSelectedCustomerId != null && customer.CustomerId == preSelectedCustomerId)
                        {
                            <option value="@customer.CustomerId" selected>@customer.FullName</option>
                        }
                        else
                        {
                            <option value="@customer.CustomerId">@customer.FullName</option>
                        }
                    }
                </select>
            </div>

            <h5 class="mt-3">Select Products</h5>
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Select</th>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Price (₹)</th>
                        <th>Stock</th>
                        <th>Quantity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in ViewBag.Products)
                    {
                        <tr>
                            <td class="text-center">
                                <input type="checkbox"
                                       name="ProductIds"
                                       value="@product.ProductId"
                                       class="form-check-input" />
                            </td>
                            <td>@product.Name</td>
                            <td>@product.Category?.Name</td>
                            <td>₹@product.Price.ToString("N0")</td>
                            <td>
                                @if (product.StockQuantity > 0)
                                {
                                    <span class="badge bg-success">@product.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Out of stock</span>
                                }
                            </td>
                            <td>
                                <input type="number"
                                       name="Quantities"
                                       value="1"
                                       min="1"
                                       max="@product.StockQuantity"
                                       class="form-control form-control-sm"
                                       style="width:80px;" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">Place Order</button>
                <a href="/Customers/Index" class="btn btn-secondary ms-2">Skip for now</a>
            </div>
        </form>
    </div>
</div>
