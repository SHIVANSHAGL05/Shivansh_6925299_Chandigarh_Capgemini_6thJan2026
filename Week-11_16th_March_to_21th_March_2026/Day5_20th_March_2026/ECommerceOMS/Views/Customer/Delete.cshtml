@model ECommerceOMS.Models.Customer
@{
    ViewData["Title"] = "Delete Customer";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Delete Customer</h5>
            </div>
            <div class="card-body">
                <p>Are you sure you want to delete <strong>@Model.FullName</strong>?</p>
                <table class="table table-sm table-borderless">
                    <tr><th>Email</th><td>@Model.Email</td></tr>
                    <tr><th>Phone</th><td>@Model.Phone</td></tr>
                    <tr><th>City</th><td>@Model.City</td></tr>
                    <tr><th>Orders</th><td>@(Model.Orders?.Count ?? 0) orders</td></tr>
                </table>
                @if (Model.Orders?.Any() == true)
                {
                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        This customer has orders. Deleting will also remove all associated orders.
                    </div>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
