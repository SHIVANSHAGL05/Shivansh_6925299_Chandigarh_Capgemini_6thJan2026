@model ECommerceOMS.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Products";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-grid me-2"></i>Products</h1>
            <p class="mb-0 opacity-75">Browse and manage the product catalogue</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-warning fw-semibold">
                <i class="bi bi-plus-lg me-1"></i>Add Product
            </a>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Sidebar Filter -->
    <div class="col-md-3">
        <div class="card p-3 filter-sidebar">
            <h6 class="fw-bold mb-3"><i class="bi bi-funnel me-2"></i>Filter</h6>

            <!-- Search -->
            <form method="get" class="mb-3">
                <div class="input-group input-group-sm">
                    <input type="text" name="search" class="form-control" placeholder="Search products…" value="@Model.SearchTerm" />
                    <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                </div>
                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
            </form>

            <!-- Sort -->
            <form method="get" class="mb-3">
                <label class="form-label small fw-semibold text-muted">Sort By</label>
                <select name="sortBy" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="" selected="@(Model.SortBy == null)">Default</option>
                    <option value="name" selected="@(Model.SortBy == "name")">Name A–Z</option>
                    <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Price: Low–High</option>
                    <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Price: High–Low</option>
                </select>
                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                <input type="hidden" name="search" value="@Model.SearchTerm" />
            </form>

            <!-- Categories -->
            <label class="form-label small fw-semibold text-muted">Categories</label>
            <div class="list-group list-group-flush">
                <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy"
                   class="list-group-item list-group-item-action d-flex justify-content-between py-2 small @(Model.SelectedCategoryId == null ? "active" : "")">
                    All Products
                    <span class="badge bg-secondary rounded-pill">@Model.Products.Count</span>
                </a>
                @foreach (var cat in Model.Categories)
                {
                    var count = Model.Products.Count(p => p.CategoryId == cat.Id);
                    <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-search="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy"
                       class="list-group-item list-group-item-action d-flex justify-content-between py-2 small @(Model.SelectedCategoryId == cat.Id ? "active" : "")">
                        @cat.Name
                        <span class="badge bg-secondary rounded-pill">@count</span>
                    </a>
                }
            </div>

            @if (Model.SelectedCategoryId != null || Model.SearchTerm != null)
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-3 w-100">
                    <i class="bi bi-x-circle me-1"></i>Clear Filters
                </a>
            }
        </div>
    </div>

    <!-- Product Grid -->
    <div class="col-md-9">
        @if (!Model.Products.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-muted opacity-25"></i>
                <h5 class="mt-3 text-muted">No products found</h5>
                <a asp-action="Index" class="btn btn-primary mt-2">Clear Filters</a>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var p in Model.Products)
                {
                    <div class="col-sm-6 col-lg-4">
                        <div class="card product-card h-100">
                            <div class="product-img-placeholder">
                                <i class="bi bi-box-seam"></i>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="badge bg-primary-subtle text-primary small">@p.Category?.Name</span>
                                    @if (p.StockQuantity <= 5 && p.StockQuantity > 0)
                                    {
                                        <span class="badge bg-warning-subtle text-warning small">Low Stock</span>
                                    }
                                    else if (p.StockQuantity == 0)
                                    {
                                        <span class="badge bg-danger-subtle text-danger small">Out of Stock</span>
                                    }
                                </div>
                                <h6 class="card-title fw-semibold">@p.Name</h6>
                                <p class="text-muted small flex-grow-1">@(p.Description?.Length > 70 ? p.Description.Substring(0, 70) + "…" : p.Description)</p>
                                @if (p.SKU != null)
                                {
                                    <p class="text-muted small mb-1"><i class="bi bi-upc me-1"></i>@p.SKU</p>
                                }
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="fs-5 fw-bold text-primary">₹@p.Price.ToString("N2")</span>
                                    <span class="text-muted small">Qty: @p.StockQuantity</span>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3 d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-outline-primary btn-sm flex-grow-1">Details</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
