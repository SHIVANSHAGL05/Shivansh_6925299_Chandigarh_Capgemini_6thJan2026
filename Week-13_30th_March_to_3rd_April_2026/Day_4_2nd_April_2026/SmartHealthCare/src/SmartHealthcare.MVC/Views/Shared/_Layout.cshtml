<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f172a" />
    <title>@ViewData["Title"] - Smart Healthcare</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var isAuthenticated = Context.Session.GetString("Token") != null;
    }
    <div class="app-background"></div>
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" asp-controller="Home" asp-action="Index">
                <span class="brand-mark"><i class="fa-solid fa-hospital"></i></span>
                <span class="brand-text">Smart Healthcare</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navBar" aria-controls="navBar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navBar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link @(currentController == "Doctor" ? "active" : "")" asp-controller="Doctor" asp-action="Index">Doctors</a></li>
                    @if (isAuthenticated)
                    {
                        <li class="nav-item"><a class="nav-link @(currentController == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link @(currentController == "Appointment" ? "active" : "")" asp-controller="Appointment" asp-action="Index">Appointments</a></li>
                        <li class="nav-item"><a class="nav-link @(currentController == "Patient" ? "active" : "")" asp-controller="Patient" asp-action="Profile">Profile</a></li>
                    }
                </ul>
                <div class="d-flex align-items-lg-center gap-2 ms-lg-auto flex-column flex-lg-row">
                    @if (isAuthenticated)
                    {
                        <div class="profile-chip">
                            <span class="chip-icon"><i class="bi bi-person-circle"></i></span>
                            <span class="navbar-text text-white-50 small text-lg-end">@Context.Session.GetString("FullName")</span>
                        </div>
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                        <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus"></i> Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="main-shell">
        <div class="container py-4 py-lg-5">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success shadow-sm border-0 toast-alert">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shadow-sm border-0 toast-alert">@TempData["Error"]</div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="container d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <span>&copy; 2026 Smart Healthcare</span>
            <span class="text-white-50">Manage care, appointments, and records in one place.</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
