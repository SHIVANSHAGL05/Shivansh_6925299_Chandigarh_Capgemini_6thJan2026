<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SmartCare</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@{
    var userName = Context.Session.GetString("UserName");
    var userRole = Context.Session.GetString("UserRole");
    var isAuth   = !string.IsNullOrEmpty(Context.Session.GetString("JwtToken"));
    var isAdmin   = userRole == "Admin";
    var isDoctor  = userRole == "Doctor";
    var isPatient = userRole == "Patient";
}

<nav class="navbar navbar-expand-lg shadow-sm">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="bi bi-hospital-fill me-2"></i>Smart<span class="brand-accent">Care</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                @if (isAuth)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    </li>

                    @if (isPatient)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Doctor" asp-action="Index">
                                <i class="bi bi-person-badge me-1"></i>Find Doctors
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointment" asp-action="Book">
                                <i class="bi bi-calendar-plus me-1"></i>Book
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointment" asp-action="Index">
                                <i class="bi bi-calendar-check me-1"></i>Appointments
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Patient" asp-action="MyBills">
                                <i class="bi bi-receipt me-1"></i>My Bills
                            </a>
                        </li>
                    }

                    @if (isDoctor)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointment" asp-action="Index">
                                <i class="bi bi-calendar-check me-1"></i>Appointments
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Prescription" asp-action="Create">
                                <i class="bi bi-file-medical me-1"></i>Prescriptions
                            </a>
                        </li>
                    }

                    @if (isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointment" asp-action="Index">
                                <i class="bi bi-calendar-check me-1"></i>Appointments
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-grid me-1"></i>Manage
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Patients"><i class="bi bi-people me-2"></i>Patients</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Doctors"><i class="bi bi-person-badge me-2"></i>Doctors</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Medicines"><i class="bi bi-capsule me-2"></i>Medicines</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Specializations"><i class="bi bi-award me-2"></i>Specializations</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Departments"><i class="bi bi-building me-2"></i>Departments</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Bills"><i class="bi bi-receipt me-2"></i>Bills &amp; Payments</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Reports"><i class="bi bi-bar-chart-line me-2"></i>Reports</a></li>
                            </ul>
                        </li>
                    }
                }
            </ul>

            <ul class="navbar-nav">
                @if (isAuth)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white text-primary" style="width:30px;height:30px;font-size:.85rem;font-weight:700;flex-shrink:0;">
                                @(userName?.Length > 0 ? userName[0].ToString().ToUpper() : "U")
                            </span>
                            <span class="d-none d-md-inline">@userName</span>
                            <span class="badge ms-1 @(isAdmin ? "role-badge-admin" : isDoctor ? "role-badge-doctor" : "role-badge-patient")">@userRole</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li class="px-3 py-2">
                                <div class="text-white-50" style="font-size:.72rem;text-transform:uppercase;letter-spacing:.5px">Signed in as</div>
                                <div class="text-white fw-600">@userName</div>
                            </li>
                            <li><hr class="dropdown-divider"></li>

                            @if (isPatient)
                            {
                                <li><a class="dropdown-item" asp-controller="Patient" asp-action="Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                <li><a class="dropdown-item" asp-controller="Patient" asp-action="MyPrescriptions"><i class="bi bi-file-medical me-2"></i>Prescriptions</a></li>
                                <li><a class="dropdown-item" asp-controller="Patient" asp-action="MyBills"><i class="bi bi-receipt me-2"></i>My Bills</a></li>
                            }
                            @if (isDoctor)
                            {
                                <li><a class="dropdown-item" asp-controller="Doctor" asp-action="EditProfile"><i class="bi bi-person me-2"></i>Edit Profile</a></li>
                            }
                            @if (isAdmin)
                            {
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Reports"><i class="bi bi-bar-chart-line me-2"></i>Reports</a></li>
                            }

                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item" style="color:#fb7185;">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i>Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main>
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</main>

<footer class="footer mt-auto py-3">
    <div class="container text-center">
        <small>&copy; @DateTime.Now.Year SmartCare — Healthcare Management System</small>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
